---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getArticleBySlug, listCategories, listSeries, getDB } from '../../../lib/db';
import { isAuthenticated } from '../../../lib/auth';
import { Pencil, Upload, Pin } from 'lucide-astro';

const isAuthed = await isAuthenticated(Astro.request, (Astro.locals as any)?.runtime?.env?.JWT_SECRET);
if (!isAuthed) return Astro.redirect('/admin/login');

const { id } = Astro.params;

let article: any = null;
let categories: any[] = [];
let seriesList: any[] = [];

try {
  const db = getDB(Astro);
  // 透過 slug 找 — 但 id 是數字，這邊先嘗試兩種
  if (id && /^\d+$/.test(id)) {
    const r = await db.prepare(`SELECT slug FROM articles WHERE id = ?`).bind(parseInt(id)).first();
    if (r) article = await getArticleBySlug(db, r.slug as string);
  } else if (id) {
    article = await getArticleBySlug(db, id);
  }
  categories = await listCategories(db);
  seriesList = await listSeries(db);
} catch (e) {
  console.error(e);
}

if (!article) {
  return Astro.redirect('/admin');
}
---

<AdminLayout>
  <header class="admin-page-head">
    <h1><Pencil size={22} /> 編輯文章</h1>
    <div style="display: flex; gap: 8px;">
      <a href={`/admin/preview/${article.id}`} target="_blank" class="btn">預覽</a>
      <a href="/admin" class="btn btn-ghost">← 返回列表</a>
    </div>
  </header>

  <form id="article-form" data-id={article.id} class="card admin-form">
    <div class="admin-edit-grid">
      <div>
        <div class="form-group">
          <label>標題</label>
          <input type="text" id="title" name="title" required value={article.title} />
        </div>
        <div class="form-group">
          <label>Slug</label>
          <input type="text" id="slug" name="slug" value={article.slug} />
        </div>
        <div class="form-group">
          <label>摘要</label>
          <textarea id="excerpt" name="excerpt" rows="2">{article.excerpt || ''}</textarea>
        </div>
        <div class="form-group">
          <label class="admin-label-row">
            <span>Markdown 內容</span>
            <span class="admin-charcount" id="char-count">{article.content_md.length} 字</span>
          </label>
          <textarea id="content_md" name="content_md" rows="20" required style="font-family: var(--font-mono); font-size: 13px;" oninput="updateCount()">{article.content_md}</textarea>
        </div>
      </div>

      <aside class="admin-meta">
        <div class="form-group">
          <label>狀態</label>
          <select id="status" name="status">
            <option value="draft" selected={article.status === 'draft'}>草稿</option>
            <option value="published" selected={article.status === 'published'}>發佈</option>
          </select>
        </div>

        <div class="form-group">
          <label>作者身分</label>
          <select id="authorship" name="authorship">
            <option value="original" selected={article.authorship === 'original'}>觀點（自寫）</option>
            <option value="ai" selected={article.authorship === 'ai' || !article.authorship}>AI 精選</option>
            <option value="translation" selected={article.authorship === 'translation'}>譯文</option>
          </select>
        </div>

        {(article.created_via || article.gen_model || article.ingest_ip) && (
          <div class="form-group">
            <label>產製來源</label>
            <p class="text-muted" style="font-size: 13px; margin: 0;">{article.created_via || '未知'}{article.gen_model ? ` · ${article.gen_model}` : ''}{article.ingest_ip ? ` · ${article.ingest_ip}` : ''}</p>
          </div>
        )}

        <div class="form-group">
          <label>原文 URL</label>
          <input type="url" id="source_url" name="source_url" value={article.source_url || ''} placeholder="https://..." />
        </div>

        <div class="form-group">
          <label>分類</label>
          <select id="category_id" name="category_id">
            <option value="">無</option>
            {categories.map((c) => (
              <option value={c.id} selected={article.category_id === c.id}>{c.name}</option>
            ))}
          </select>
        </div>

        <div class="form-group">
          <label>合集</label>
          <select id="series_id" name="series_id">
            <option value="">無</option>
            {seriesList.map((s) => (
              <option value={s.id} selected={article.series_id === s.id}>{s.title}</option>
            ))}
          </select>
        </div>

        <div class="form-group">
          <label>合集內順序</label>
          <input type="number" id="series_order" name="series_order" min="0" value={article.series_order || 0} />
        </div>

        <div class="form-group">
          <label>標籤（逗號分隔）</label>
          <input type="text" id="tags" name="tags" value={article.tags.map((t: any) => t.slug).join(', ')} />
        </div>

        <div class="form-group">
          <label>封面圖 URL</label>
          <input type="text" id="cover_image" name="cover_image" value={article.cover_image || ''} />
          <button type="button" id="upload-btn" class="btn admin-upload-btn"><Upload size={14} /> 上傳圖片</button>
          <input type="file" id="file-input" accept="image/*" style="display: none;" />
          {article.cover_image && <img src={article.cover_image} class="admin-cover-preview" />}
        </div>

        <div class="form-group">
          <label class="admin-check">
            <input type="checkbox" id="is_featured" name="is_featured" checked={!!article.is_featured} />
            <span>今日觀點（首頁主位，取最新一篇）</span>
          </label>
          <label class="admin-check" style="margin-top: 8px;">
            <input type="checkbox" id="is_pinned" name="is_pinned" checked={!!article.is_pinned} />
            <Pin size={16} />
            <span>置頂（首頁右欄）</span>
          </label>
        </div>

        <button type="submit" class="btn btn-primary admin-submit">更新</button>
        <div id="result" class="admin-result"></div>
      </aside>
    </div>
  </form>

  <style>
    .admin-page-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 28px;
    }
    .admin-page-head h1 {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -.02em;
    }
    .admin-page-head h1 svg { color: var(--accent); }

    .admin-form { padding: 28px; }
    .admin-form:hover { transform: none; box-shadow: var(--shadow-sm); border-color: var(--border); }

    .admin-edit-grid {
      display: grid;
      grid-template-columns: minmax(0, 2fr) minmax(260px, 1fr);
      gap: 28px;
    }
    .admin-meta {
      align-self: start;
      padding: 20px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .admin-label-row { display: flex; justify-content: space-between; align-items: baseline; }
    .admin-charcount { font-size: 12px; font-weight: 500; color: var(--text-muted); }
    .admin-check {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 0;
      cursor: pointer;
      color: var(--text-primary);
    }
    .admin-check input { width: auto; }
    .admin-upload-btn {
      margin-top: 8px;
      width: 100%;
      justify-content: center;
      font-size: 12px;
    }
    .admin-cover-preview {
      margin-top: 8px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
    }
    .admin-submit { width: 100%; margin-top: 16px; justify-content: center; }
    .admin-result { margin-top: 12px; font-size: 13px; }

    @media (max-width: 820px) {
      .admin-edit-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    const contentEl = document.getElementById('content_md') as HTMLTextAreaElement;
    const charCount = document.getElementById('char-count')!;
    const form = document.getElementById('article-form') as HTMLFormElement;
    const result = document.getElementById('result')!;
    const articleId = form.dataset.id;

    // lucide inline SVG for runtime-built status messages (no emoji)
    const ICON: Record<string, string> = {
      check: '<path d="M20 6 9 17l-5-5"/>',
      x: '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>',
    };
    const ic = (n: string) =>
      `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px">${ICON[n] || ''}</svg>`;
    const escHtml = (s: string) =>
      (s || '').replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c] as string));

    (window as any).updateCount = () => {
      charCount.textContent = `${contentEl.value.length} 字`;
    };

    document.getElementById('upload-btn')?.addEventListener('click', () => {
      (document.getElementById('file-input') as HTMLInputElement).click();
    });

    document.getElementById('file-input')?.addEventListener('change', async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;
      const fd = new FormData();
      fd.append('file', file);
      result.textContent = '上傳中...';
      result.style.color = 'var(--accent)';
      try {
        const res = await fetch('/api/upload', { method: 'POST', body: fd });
        if (!res.ok) throw new Error('上傳失敗');
        const data = await res.json();
        (document.getElementById('cover_image') as HTMLInputElement).value = data.url;
        result.innerHTML = ic('check') + '上傳成功';
        result.style.color = 'var(--accent-green)';
      } catch (err: any) {
        result.innerHTML = ic('x') + escHtml(err.message);
        result.style.color = 'var(--accent-red)';
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      result.textContent = '更新中...';
      result.style.color = 'var(--accent)';

      const fd = new FormData(form);
      const body: any = {
        title: fd.get('title'),
        slug: fd.get('slug'),
        excerpt: fd.get('excerpt'),
        content_md: fd.get('content_md'),
        cover_image: fd.get('cover_image'),
        authorship: fd.get('authorship'),
        source_url: (fd.get('source_url') as string || '').trim() || null,
        status: fd.get('status'),
        category_id: fd.get('category_id') ? parseInt(fd.get('category_id') as string) : null,
        series_id: fd.get('series_id') ? parseInt(fd.get('series_id') as string) : null,
        series_order: fd.get('series_order') ? parseInt(fd.get('series_order') as string) : 0,
        tags: (fd.get('tags') as string || '').split(',').map((s) => s.trim()).filter(Boolean),
        is_featured: (document.getElementById('is_featured') as HTMLInputElement).checked,
        is_pinned: (document.getElementById('is_pinned') as HTMLInputElement).checked,
      };

      try {
        const res = await fetch(`/api/articles?id=${articleId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || '更新失敗');
        }
        result.innerHTML = ic('check') + '已更新 — <a href="/admin">返回列表</a> · <a href="/post/' + encodeURIComponent(body.slug) + '" target="_blank">檢視</a>';
        result.style.color = 'var(--accent-green)';
      } catch (err: any) {
        result.innerHTML = ic('x') + escHtml(err.message);
        result.style.color = 'var(--accent-red)';
      }
    });
  </script>
</AdminLayout>