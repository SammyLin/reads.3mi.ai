---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { ClipboardList } from 'lucide-astro';
---

<AdminLayout>
  <header class="admin-page-head">
    <h1><ClipboardList size={22} /> 文章管理</h1>
    <div style="display: flex; gap: 8px;">
      <a href="/admin/subscribers" class="btn">訂閱名單</a>
      <a href="/admin/new" class="btn btn-primary">新增文章</a>
    </div>
  </header>

  <div id="auth-check" class="card admin-placeholder">
    <p>驗證登入中...</p>
  </div>

  <div id="admin-content" style="display: none;">
    <div class="card admin-table-card">
      <table class="admin-table">
        <thead>
          <tr>
            <th>標題</th>
            <th>分類</th>
            <th>狀態</th>
            <th>更新</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody id="articles-tbody">
          <tr><td colspan="5" class="admin-table-empty">載入中...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <style>
    .admin-page-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 28px;
    }
    .admin-page-head h1 {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -.02em;
    }
    .admin-page-head h1 svg { color: var(--accent); }

    .admin-placeholder {
      padding: 48px;
      text-align: center;
      color: var(--text-muted);
    }
    .admin-placeholder:hover { transform: none; box-shadow: var(--shadow-sm); border-color: var(--border); }

    .admin-table-card {
      padding: 0;
      overflow: hidden;
    }
    .admin-table-card:hover { transform: none; box-shadow: var(--shadow-sm); border-color: var(--border); }

    .admin-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    .admin-table thead th {
      text-align: left;
      padding: 14px 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--text-muted);
      background: var(--bg-tertiary);
      border-bottom: 1px solid var(--border);
    }
    .admin-table tbody td {
      padding: 14px 20px;
      border-top: 1px solid var(--border);
      vertical-align: middle;
    }
    .admin-table tbody tr:first-child td { border-top: none; }
    .admin-table tbody tr { transition: background var(--dur-fast) var(--ease); }
    .admin-table tbody tr:hover { background: var(--bg-tertiary); }
    .admin-table-empty {
      padding: 48px !important;
      text-align: center;
      color: var(--text-muted);
    }
    .admin-title { font-weight: 600; color: var(--text-primary); }
    .admin-table td:nth-child(2),
    .admin-table td:nth-child(3),
    .admin-table td:nth-child(4),
    .admin-table td:nth-child(5) { white-space: nowrap; width: 1%; }
    .admin-status {
      display: inline-flex;
      align-items: center;
      font-size: 12px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 999px;
    }
    .admin-status.is-published { background: rgba(21,128,61,.12); color: #15803d; }
    .admin-status.is-draft { background: var(--accent-soft); color: var(--accent-hover); }
    .admin-date { font-size: 13px; color: var(--text-muted); }
    .admin-actions { display: inline-flex; gap: 6px; flex-wrap: nowrap; }
    .admin-actions .btn { font-size: 12px; padding: 5px 11px; }
    .admin-actions .btn-danger {
      background: transparent;
      border: 1px solid rgba(248, 81, 73, .35);
      color: #d1242f;
    }
    .admin-actions .btn-danger:hover {
      background: rgba(248, 81, 73, .08);
      border-color: #d1242f;
    }
  </style>

  <script>
    async function init() {
      // Check auth
      const authRes = await fetch('/api/auth');
      const { authenticated } = authRes.ok ? await authRes.json() : { authenticated: false };
      if (!authenticated) {
        window.location.href = '/admin/login';
        return;
      }

      document.getElementById('auth-check').style.display = 'none';
      document.getElementById('admin-content').style.display = 'block';

      // Load articles
      const res = await fetch('/api/articles?scope=admin');
      if (res.status === 401) {
        window.location.href = '/admin/login';
        return;
      }
      const { articles = [] } = await res.json();

      const tbody = document.getElementById('articles-tbody');
      if (!tbody) return;

      if (articles.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="admin-table-empty">還沒有文章。<a href="/admin/new">寫第一篇 →</a></td></tr>';
        return;
      }

      tbody.innerHTML = articles.map((a) => `
        <tr>
          <td>
            <div class="admin-title">${escapeHtml(a.title)}</div>
          </td>
          <td>
            ${a.category ? `<span class="tag" style="background: ${a.category.color}22; color: ${a.category.color}; border-color: ${a.category.color}33;">${escapeHtml(a.category.name)}</span>` : ''}
          </td>
          <td>
            <span class="admin-status ${a.status === 'published' ? 'is-published' : 'is-draft'}">
              ${a.status === 'published' ? '已發佈' : '草稿'}
            </span>
            ${a.is_featured ? '<span style="margin-left: 6px; display: inline-flex; vertical-align: middle;" title="焦點文章"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="var(--accent)" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg></span>' : ''}
          </td>
          <td>
            <span class="admin-date">${(a.updated_at || '').slice(0, 10)}</span>
          </td>
          <td>
            <span class="admin-actions">
              <a href="/admin/edit/${a.id}" class="btn">編輯</a>
              <a href="/post/${escapeHtml(a.slug)}" target="_blank" class="btn">檢視</a>
              <button data-id="${a.id}" data-title="${escapeHtml(a.title)}" class="btn btn-danger" onclick="deleteArticle(this.dataset.id, this.dataset.title)">刪除</button>
            </span>
          </td>
        </tr>
      `).join('');
    }

    function escapeHtml(s) {
      if (typeof s !== 'string') return '';
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    window.deleteArticle = async (id, title) => {
      if (!confirm(`確定要刪除「${title}」嗎？此操作無法復原。`)) return;
      const res = await fetch(`/api/articles?id=${id}`, { method: 'DELETE' });
      if (res.ok) {
        window.location.reload();
      } else {
        alert('刪除失敗');
      }
    };

    init();
  </script>
</AdminLayout>
