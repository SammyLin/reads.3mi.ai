---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <div style="max-width: 1200px; margin: 0 auto; padding: 32px 24px;">
    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
      <h1 style="font-size: 24px;">📋 文章管理</h1>
      <div style="display: flex; gap: 8px;">
        <a href="/" class="btn btn-ghost">看前台</a>
        <a href="/admin/new" class="btn btn-primary">+ 新增文章</a>
        <button id="logout-btn" class="btn">登出</button>
      </div>
    </header>

    <div id="auth-check" style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 40px; text-align: center;">
      <p>驗證登入中...</p>
    </div>

    <div id="admin-content" style="display: none;">
      <div style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="background: var(--bg-tertiary); text-align: left;">
              <th style="padding: 12px 16px; font-size: 12px; color: var(--text-muted); text-transform: uppercase;">標題</th>
              <th style="padding: 12px 16px; font-size: 12px; color: var(--text-muted); text-transform: uppercase;">分類</th>
              <th style="padding: 12px 16px; font-size: 12px; color: var(--text-muted); text-transform: uppercase;">狀態</th>
              <th style="padding: 12px 16px; font-size: 12px; color: var(--text-muted); text-transform: uppercase;">更新</th>
              <th style="padding: 12px 16px; font-size: 12px; color: var(--text-muted); text-transform: uppercase;">操作</th>
            </tr>
          </thead>
          <tbody id="articles-tbody">
            <tr><td colspan="5" style="padding: 40px; text-align: center; color: var(--text-muted);">載入中...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    async function init() {
      // Check auth
      const authRes = await fetch('/api/auth');
      if (!authRes.ok) {
        window.location.href = '/admin/login';
        return;
      }

      document.getElementById('auth-check').style.display = 'none';
      document.getElementById('admin-content').style.display = 'block';

      // Load articles
      const res = await fetch('/api/articles');
      const { articles = [] } = await res.json();

      const tbody = document.getElementById('articles-tbody');
      if (!tbody) return;

      if (articles.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="padding: 40px; text-align: center; color: var(--text-muted);">還沒有文章。<a href="/admin/new">寫第一篇 →</a></td></tr>';
        return;
      }

      tbody.innerHTML = articles.map((a) => `
        <tr style="border-top: 1px solid var(--border);">
          <td style="padding: 12px 16px;">
            <div style="font-weight: 500;">${escapeHtml(a.title)}</div>
            <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">/${escapeHtml(a.slug)}</div>
          </td>
          <td style="padding: 12px 16px;">
            ${a.category ? `<span class="tag" style="background: ${a.category.color}22; color: ${a.category.color};">${a.category.icon} ${escapeHtml(a.category.name)}</span>` : ''}
          </td>
          <td style="padding: 12px 16px;">
            <span style="font-size: 12px; padding: 2px 8px; border-radius: 12px; ${a.status === 'published' ? 'background: rgba(63,185,80,0.15); color: var(--accent-green);' : 'background: rgba(240,136,62,0.15); color: var(--accent-warm);'}">
              ${a.status === 'published' ? '已發佈' : '草稿'}
            </span>
            ${a.is_featured ? '<span style="margin-left: 4px; font-size: 12px;">⭐</span>' : ''}
          </td>
          <td style="padding: 12px 16px; font-size: 13px; color: var(--text-muted);">
            ${(a.updated_at || '').slice(0, 10)}
          </td>
          <td style="padding: 12px 16px;">
            <a href="/admin/edit/${a.id}" class="btn" style="font-size: 12px; padding: 4px 10px;">編輯</a>
            <a href="/post/${escapeHtml(a.slug)}" target="_blank" class="btn" style="font-size: 12px; padding: 4px 10px;">檢視</a>
            <button data-id="${a.id}" data-title="${escapeHtml(a.title)}" class="btn btn-danger" style="font-size: 12px; padding: 4px 10px;" onclick="deleteArticle(this.dataset.id, this.dataset.title)">刪除</button>
          </td>
        </tr>
      `).join('');
    }

    function escapeHtml(s) {
      if (typeof s !== 'string') return '';
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth', { method: 'DELETE' });
      window.location.href = '/admin/login';
    });

    window.deleteArticle = async (id, title) => {
      if (!confirm(`確定要刪除「${title}」嗎？此操作無法復原。`)) return;
      const res = await fetch(`/api/articles?id=${id}`, { method: 'DELETE' });
      if (res.ok) {
        window.location.reload();
      } else {
        alert('刪除失敗');
      }
    };

    init();
  </script>
</AdminLayout>