---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { PenLine, Star } from 'lucide-astro';
---

<AdminLayout>
  <header class="admin-page-head">
    <div>
      <h1><PenLine size={22} /> 新增文章</h1>
      <a href="/admin" class="admin-back">← 返回列表</a>
    </div>
  </header>

  <div id="auth-check" class="card admin-placeholder">
    <p>驗證登入中...</p>
  </div>

  <form id="article-form" class="card admin-form" style="display: none;">
    <div class="form-group">
      <label>標題 *</label>
      <input id="title" type="text" required>
    </div>
    <div class="form-group">
      <label>Slug *</label>
      <input id="slug" type="text" required>
      <small class="admin-hint">URL: /post/<span id="slug-preview">your-slug</span></small>
    </div>
    <div class="form-group">
      <label>分類</label>
      <select id="category">
        <option value="">無</option>
      </select>
    </div>
    <div class="form-group">
      <label>作者身分</label>
      <select id="authorship">
        <option value="original" selected>觀點（自寫）</option>
        <option value="ai">AI 精選</option>
        <option value="translation">譯文（需填原文 source_url）</option>
      </select>
    </div>
    <div class="form-group">
      <label>原文 URL（譯文 / 有來源時填）</label>
      <input id="source_url" type="url" placeholder="https://...">
    </div>
    <div class="form-group">
      <label>合集</label>
      <select id="series">
        <option value="">無</option>
      </select>
    </div>
    <div class="form-group">
      <label>合集內順序</label>
      <input id="series_order" type="number" min="0" value="0">
    </div>
    <div class="form-group">
      <label>Excerpt</label>
      <textarea id="excerpt" rows="2"></textarea>
    </div>
    <div class="form-group">
      <label>內容 (Markdown) *</label>
      <textarea id="content_md" rows="20" required style="font-family: var(--font-mono); font-size: 13px;"></textarea>
    </div>
    <div class="form-group">
      <label class="admin-check"><input id="is_featured" type="checkbox"> <Star size={16} /> <span>設為焦點文章</span></label>
    </div>
    <div id="form-error" class="admin-form-error"></div>
    <div class="admin-form-actions">
      <button type="submit" class="btn btn-primary">儲存為草稿</button>
      <button type="button" id="publish-btn" class="btn btn-primary">發佈</button>
      <a href="/admin" class="btn btn-ghost">取消</a>
    </div>
  </form>

  <style>
    .admin-page-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 28px;
    }
    .admin-page-head h1 {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -.02em;
    }
    .admin-page-head h1 svg { color: var(--accent); }
    .admin-back {
      display: inline-block;
      margin-top: 8px;
      font-size: 13px;
      color: var(--text-secondary);
      border-bottom: none;
    }
    .admin-back:hover { color: var(--accent); border-bottom: none; }

    .admin-placeholder {
      padding: 48px;
      text-align: center;
      color: var(--text-muted);
    }
    .admin-placeholder:hover { transform: none; box-shadow: var(--shadow-sm); border-color: var(--border); }

    .admin-form { padding: 28px; }
    .admin-form:hover { transform: none; box-shadow: var(--shadow-sm); border-color: var(--border); }
    .admin-hint { display: block; margin-top: 6px; color: var(--text-muted); font-size: 12px; }
    .admin-check {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 0;
      cursor: pointer;
      color: var(--text-primary);
    }
    .admin-check input { width: auto; }
    .admin-check svg { color: var(--accent); }
    .admin-form-error {
      display: none;
      color: var(--cat-security);
      margin-bottom: 12px;
      font-size: 13px;
    }
    .admin-form-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      padding-top: 8px;
      border-top: 1px solid var(--border);
      margin-top: 4px;
    }
  </style>

  <script>
    async function init() {
      const authRes = await fetch('/api/auth');
      const { authenticated } = authRes.ok ? await authRes.json() : { authenticated: false };
      if (!authenticated) {
        window.location.href = '/admin/login';
        return;
      }

      document.getElementById('auth-check').style.display = 'none';
      document.getElementById('article-form').style.display = 'block';

      // Load categories
      const catRes = await fetch('/api/categories');
      const { categories = [] } = await catRes.json();
      const catSelect = document.getElementById('category');
      categories.forEach((c) => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name;
        catSelect.appendChild(opt);
      });

      // Load series
      const serRes = await fetch('/api/series');
      const { series = [] } = await serRes.json();
      const serSelect = document.getElementById('series');
      series.forEach((s) => {
        const opt = document.createElement('option');
        opt.value = s.id;
        opt.textContent = s.title;
        serSelect.appendChild(opt);
      });

      // Auto-generate slug from title
      document.getElementById('title').addEventListener('input', (e) => {
        const title = e.target.value;
        const slugInput = document.getElementById('slug');
        if (!slugInput.dataset.touched) {
          const slug = slugify(title);
          slugInput.value = slug;
          document.getElementById('slug-preview').textContent = slug;
        }
      });
      document.getElementById('slug').addEventListener('input', (e) => {
        e.target.dataset.touched = '1';
        document.getElementById('slug-preview').textContent = e.target.value;
      });
    }

    function slugify(title) {
      return title
        .toLowerCase()
        .trim()
        .replace(/[\u4e00-\u9fff]+/g, (m) => encodeURIComponent(m))
        .replace(/[^a-z0-9\u4e00-\u9fff\-]+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '')
        .slice(0, 80);
    }

    async function submitForm(status) {
      const data = {
        title: document.getElementById('title').value,
        slug: document.getElementById('slug').value,
        excerpt: document.getElementById('excerpt').value,
        content_md: document.getElementById('content_md').value,
        authorship: document.getElementById('authorship').value,
        source_url: document.getElementById('source_url').value.trim() || null,
        category_id: parseInt(document.getElementById('category').value) || null,
        series_id: parseInt(document.getElementById('series').value) || null,
        series_order: parseInt(document.getElementById('series_order').value) || 0,
        is_featured: document.getElementById('is_featured').checked ? 1 : 0,
        status,
      };
      const errorEl = document.getElementById('form-error');
      errorEl.style.display = 'none';

      const res = await fetch('/api/articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        window.location.href = '/admin';
      } else {
        const err = await res.json();
        errorEl.textContent = err.error || '儲存失敗';
        errorEl.style.display = 'block';
      }
    }

    document.getElementById('article-form').addEventListener('submit', (e) => {
      e.preventDefault();
      submitForm('draft');
    });
    document.getElementById('publish-btn').addEventListener('click', () => {
      submitForm('published');
    });

    init();
  </script>
</AdminLayout>