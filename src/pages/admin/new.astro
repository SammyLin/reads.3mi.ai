---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { PenLine, Star } from 'lucide-astro';
---

<AdminLayout>
  <div style="max-width: 900px; margin: 0 auto; padding: 32px 24px;">
    <header style="margin-bottom: 24px;">
      <h1 style="font-size: 24px; display: flex; align-items: center; gap: 8px;"><PenLine size={22} /> 新增文章</h1>
      <a href="/admin" class="btn btn-ghost" style="margin-top: 8px;">← 返回列表</a>
    </header>

    <div id="auth-check" style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 40px; text-align: center;">
      <p>驗證登入中...</p>
    </div>

    <form id="article-form" style="display: none; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px;">
      <div style="margin-bottom: 16px;">
        <label style="display: block; margin-bottom: 4px; font-weight: 600;">標題 *</label>
        <input id="title" type="text" required style="width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg-tertiary); color: var(--text);">
      </div>
      <div style="margin-bottom: 16px;">
        <label style="display: block; margin-bottom: 4px; font-weight: 600;">Slug *</label>
        <input id="slug" type="text" required style="width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg-tertiary); color: var(--text);">
        <small style="color: var(--text-muted);">URL: /post/<span id="slug-preview">your-slug</span></small>
      </div>
      <div style="margin-bottom: 16px;">
        <label style="display: block; margin-bottom: 4px; font-weight: 600;">分類</label>
        <select id="category" style="width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg-tertiary); color: var(--text);">
          <option value="">無</option>
        </select>
      </div>
      <div style="margin-bottom: 16px;">
        <label style="display: block; margin-bottom: 4px; font-weight: 600;">Excerpt</label>
        <textarea id="excerpt" rows="2" style="width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg-tertiary); color: var(--text);"></textarea>
      </div>
      <div style="margin-bottom: 16px;">
        <label style="display: block; margin-bottom: 4px; font-weight: 600;">內容 (Markdown) *</label>
        <textarea id="content_md" rows="20" required style="width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg-tertiary); color: var(--text); font-family: monospace;"></textarea>
      </div>
      <div style="margin-bottom: 16px;">
        <label style="display: flex; align-items: center; gap: 6px;"><input id="is_featured" type="checkbox"> <Star size={16} /> 設為焦點文章</label>
      </div>
      <div id="form-error" style="color: var(--accent-red); margin-bottom: 12px; display: none;"></div>
      <div style="display: flex; gap: 8px;">
        <button type="submit" class="btn btn-primary">儲存為草稿</button>
        <button type="button" id="publish-btn" class="btn btn-primary">發佈</button>
        <a href="/admin" class="btn btn-ghost">取消</a>
      </div>
    </form>
  </div>

  <script>
    async function init() {
      const authRes = await fetch('/api/auth');
      if (!authRes.ok) {
        window.location.href = '/admin/login';
        return;
      }

      document.getElementById('auth-check').style.display = 'none';
      document.getElementById('article-form').style.display = 'block';

      // Load categories
      const catRes = await fetch('/api/categories');
      const { categories = [] } = await catRes.json();
      const catSelect = document.getElementById('category');
      categories.forEach((c) => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = `${c.icon} ${c.name}`;
        catSelect.appendChild(opt);
      });

      // Auto-generate slug from title
      document.getElementById('title').addEventListener('input', (e) => {
        const title = e.target.value;
        const slugInput = document.getElementById('slug');
        if (!slugInput.dataset.touched) {
          const slug = slugify(title);
          slugInput.value = slug;
          document.getElementById('slug-preview').textContent = slug;
        }
      });
      document.getElementById('slug').addEventListener('input', (e) => {
        e.target.dataset.touched = '1';
        document.getElementById('slug-preview').textContent = e.target.value;
      });
    }

    function slugify(title) {
      return title
        .toLowerCase()
        .trim()
        .replace(/[\u4e00-\u9fff]+/g, (m) => encodeURIComponent(m))
        .replace(/[^a-z0-9\u4e00-\u9fff\-]+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '')
        .slice(0, 80);
    }

    async function submitForm(status) {
      const data = {
        title: document.getElementById('title').value,
        slug: document.getElementById('slug').value,
        excerpt: document.getElementById('excerpt').value,
        content_md: document.getElementById('content_md').value,
        category_id: parseInt(document.getElementById('category').value) || null,
        is_featured: document.getElementById('is_featured').checked ? 1 : 0,
        status,
      };
      const errorEl = document.getElementById('form-error');
      errorEl.style.display = 'none';

      const res = await fetch('/api/articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        window.location.href = '/admin';
      } else {
        const err = await res.json();
        errorEl.textContent = err.error || '儲存失敗';
        errorEl.style.display = 'block';
      }
    }

    document.getElementById('article-form').addEventListener('submit', (e) => {
      e.preventDefault();
      submitForm('draft');
    });
    document.getElementById('publish-btn').addEventListener('click', () => {
      submitForm('published');
    });

    init();
  </script>
</AdminLayout>