---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Mail, Download } from 'lucide-astro';
---

<AdminLayout>
  <header class="admin-page-head">
    <div>
      <h1><Mail size={22} /> 訂閱名單</h1>
      <a href="/admin" class="admin-back">← 返回文章管理</a>
    </div>
    <a href="/api/subscribe?format=csv" class="btn btn-primary"><Download size={14} /> 匯出 CSV</a>
  </header>

  <div id="auth-check" class="card admin-placeholder">
    <p>驗證登入中...</p>
  </div>

  <div id="admin-content" style="display: none;">
    <p class="subscriber-summary">共 <strong id="subscriber-total">0</strong> 位訂閱者</p>
    <div class="card admin-table-card">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Email</th>
            <th>狀態</th>
            <th>來源</th>
            <th>訂閱時間</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody id="subscribers-tbody">
          <tr><td colspan="5" class="admin-table-empty">載入中...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <style>
    .admin-page-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 28px;
    }
    .admin-page-head h1 {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -.02em;
    }
    .admin-page-head h1 svg { color: var(--accent); }
    .admin-back {
      display: inline-block;
      margin-top: 8px;
      font-size: 13px;
      color: var(--text-secondary);
      border-bottom: none;
    }
    .admin-back:hover { color: var(--accent); border-bottom: none; }

    .admin-placeholder {
      padding: 48px;
      text-align: center;
      color: var(--text-muted);
    }
    .admin-placeholder:hover { transform: none; box-shadow: var(--shadow-sm); border-color: var(--border); }

    .subscriber-summary { margin-bottom: 14px; color: var(--text-secondary); font-size: 14px; }
    .subscriber-summary strong { color: var(--text-primary); font-size: 16px; }

    .admin-table-card { padding: 0; overflow: hidden; }
    .admin-table-card:hover { transform: none; box-shadow: var(--shadow-sm); border-color: var(--border); }

    .admin-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    .admin-table thead th {
      text-align: left;
      padding: 14px 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--text-muted);
      background: var(--bg-tertiary);
      border-bottom: 1px solid var(--border);
    }
    .admin-table tbody td {
      padding: 14px 20px;
      border-top: 1px solid var(--border);
      vertical-align: middle;
    }
    .admin-table tbody tr:first-child td { border-top: none; }
    .admin-table tbody tr:hover { background: var(--bg-tertiary); }
    .admin-table-empty {
      padding: 48px !important;
      text-align: center;
      color: var(--text-muted);
    }
    .admin-table td:nth-child(n+2) { white-space: nowrap; width: 1%; }
    .subscriber-email { font-weight: 600; color: var(--text-primary); font-family: var(--font-mono); font-size: 13px; }

    .admin-status {
      display: inline-flex;
      align-items: center;
      font-size: 12px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 999px;
    }
    .admin-status.is-subscribed { background: rgba(21,128,61,.12); color: #15803d; }
    .admin-status.is-pending { background: var(--accent-soft); color: var(--accent-hover); }
    .admin-status.is-unsubscribed { background: rgba(120,113,108,.12); color: var(--text-muted); }

    .admin-date, .admin-source { font-size: 13px; color: var(--text-muted); }
    .btn-danger {
      background: transparent;
      border: 1px solid rgba(248, 81, 73, .35);
      color: #d1242f;
      font-size: 12px;
      padding: 5px 11px;
    }
    .btn-danger:hover { background: rgba(248, 81, 73, .08); border-color: #d1242f; }
  </style>

  <script>
    const STATUS_LABEL = { subscribed: '已訂閱', pending: '待確認', unsubscribed: '已退訂' };

    async function init() {
      const authRes = await fetch('/api/auth');
      const { authenticated } = authRes.ok ? await authRes.json() : { authenticated: false };
      if (!authenticated) {
        window.location.href = '/admin/login';
        return;
      }

      document.getElementById('auth-check').style.display = 'none';
      document.getElementById('admin-content').style.display = 'block';

      const res = await fetch('/api/subscribe');
      if (res.status === 401) {
        window.location.href = '/admin/login';
        return;
      }
      const { total = 0, subscribers = [] } = await res.json();

      document.getElementById('subscriber-total').textContent = String(total);
      const tbody = document.getElementById('subscribers-tbody');
      if (!tbody) return;

      if (subscribers.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="admin-table-empty">還沒有訂閱者。訂閱框在站上 footer 與每篇文章尾。</td></tr>';
        return;
      }

      tbody.innerHTML = subscribers.map((s) => `
        <tr>
          <td><span class="subscriber-email">${escapeHtml(s.email)}</span></td>
          <td><span class="admin-status is-${escapeHtml(s.status)}">${STATUS_LABEL[s.status] || escapeHtml(s.status)}</span></td>
          <td><span class="admin-source">${escapeHtml(s.source || '—')}</span></td>
          <td><span class="admin-date">${(s.created_at || '').slice(0, 16).replace('T', ' ')}</span></td>
          <td><button data-id="${s.id}" data-email="${escapeHtml(s.email)}" class="btn btn-danger" onclick="removeSubscriber(this.dataset.id, this.dataset.email)">刪除</button></td>
        </tr>
      `).join('');
    }

    function escapeHtml(s) {
      if (typeof s !== 'string') return '';
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    window.removeSubscriber = async (id, email) => {
      if (!confirm(`確定要刪除訂閱者「${email}」嗎？此操作無法復原。`)) return;
      const res = await fetch(`/api/subscribe?id=${id}`, { method: 'DELETE' });
      if (res.ok) {
        window.location.reload();
      } else {
        alert('刪除失敗');
      }
    };

    init();
  </script>
</AdminLayout>
