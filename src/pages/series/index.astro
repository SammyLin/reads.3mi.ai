---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="主題合集" description="按主題整理現有文章，快速找到想讀的內容。" wide={true}>
  <header class="collection-header">
    <p class="eyebrow">Topics</p>
    <h1>主題合集</h1>
    <p>從現有文章出發，按主題快速找到值得讀的內容。</p>
  </header>

  <div id="series-content">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>

  <section id="series-latest" class="series-latest" hidden>
    <div class="collection-section-heading">
      <p class="eyebrow">Start here</p>
      <h2>先從最新文章開始</h2>
    </div>
    <div id="series-latest-list" class="collection-list"></div>
  </section>
</BaseLayout>

<script>
  import { coverThumb } from '../../lib/cover';

  function escapeHtml(s: string) {
    return (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  async function loadSeries() {
    const container = document.getElementById('series-content');
    if (!container) return;
    try {
      const articlesRes = await fetch('/api/articles?limit=100');
      const { articles = [] } = await articlesRes.json();
      const topicMap = new Map<string, any>();
      for (const article of articles) {
        if (!article.category) continue;
        const key = article.category.slug;
        const topic = topicMap.get(key) || {
          ...article.category,
          article_count: 0,
          cover_image: article.cover_image,
        };
        topic.article_count += 1;
        if (!topic.cover_image && article.cover_image) topic.cover_image = article.cover_image;
        topicMap.set(key, topic);
      }
      const topics = Array.from(topicMap.values()).sort((a, b) => b.article_count - a.article_count);
      if (topics.length === 0) {
        container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">目前還沒有已發布文章。</div>';
        return;
      }
      container.innerHTML = '<div class="series-grid">' + topics.map((topic: any) => `
        <a href="/category/${escapeHtml(topic.slug)}" class="card series-card" style="--topic-color:${escapeHtml(topic.color || '#ca8a04')}">
          ${coverThumb({ ...topic, category: topic }, 'card-thumb series-card-thumb')}
          <div class="series-card-count">${topic.article_count} 篇文章</div>
          <h2>${escapeHtml(topic.name)}</h2>
          ${topic.description ? `<p>${escapeHtml(topic.description)}</p>` : ''}
          <span class="series-card-link">探索主題 →</span>
        </a>
      `).join('') + '</div>';

      const latest = document.getElementById('series-latest');
      const latestList = document.getElementById('series-latest-list');
      if (latest && latestList && articles.length) {
        latestList.innerHTML = articles.slice(0, 6).map((a: any) => `
          <a href="/post/${escapeHtml(a.slug)}" class="collection-card">
            <div class="collection-card-body">
              <div class="collection-card-meta">
                ${a.category ? `<span style="color:${a.category.color}">${escapeHtml(a.category.name)}</span>` : ''}
                <time>${a.published_at ? new Date(a.published_at).toLocaleDateString('zh-TW') : ''}</time>
                <span>${a.reading_time || 1} 分鐘</span>
              </div>
              <h3>${escapeHtml(a.title)}</h3>
              ${a.excerpt ? `<p>${escapeHtml(a.excerpt)}</p>` : ''}
            </div>
            ${coverThumb(a, 'card-thumb collection-thumb')}
          </a>`).join('');
        latest.hidden = false;
      }
    } catch (e) {
      container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
    }
  }

  loadSeries();
</script>

<style is:global>
  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
    gap: clamp(16px, 2vw, 28px);
  }
  .series-latest { margin-top: clamp(48px, 8vw, 80px); }
  .series-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    min-width: 0;
  }
  .series-card .series-card-thumb {
    margin: -24px -24px 8px;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }
  .series-card-count {
    font-size: 12px;
    font-weight: 600;
    color: var(--topic-color, var(--accent));
    text-transform: uppercase;
    letter-spacing: .06em;
  }
  .series-card h2 {
    font-size: clamp(22px, 2.2vw, 30px);
    letter-spacing: -.02em;
  }
  .series-card p {
    color: var(--text-secondary);
    font-size: 14px;
    line-height: 1.6;
    flex: 1;
  }
  .series-card-link {
    margin-top: 4px;
    font-size: 13px;
    font-weight: 500;
    color: var(--topic-color, var(--accent));
  }
  @media (max-width: 520px) {
    .series-grid { grid-template-columns: minmax(0, 1fr); }
    .series-card { padding: 18px; }
    .series-card .series-card-thumb { margin: -18px -18px 8px; }
  }
</style>
