---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDB } from '../../lib/db';

export async function getStaticPaths() {
  // Build-time: hardcode known slugs (since D1 binding isn't available)
  // When new categories are added, update this list and redeploy
  return [
    { params: { slug: 'ai' } },
    { params: { slug: 'architecture' } },
    { params: { slug: 'tools' } },
    { params: { slug: 'tutorial' } },
    { params: { slug: 'security' } },
    { params: { slug: 'life' } },
  ];
}

const { slug } = Astro.params;
---

<BaseLayout title="分類" description="">
  <header style="margin-bottom: 32px; padding-bottom: 16px; border-bottom: 1px solid var(--border);">
    <h1 style="font-size: 28px;" id="category-title">📁 分類</h1>
    <p class="text-secondary" style="margin-top: 8px;" id="category-description"></p>
  </header>

  <div id="articles-container">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>

  <script is:inline define:vars={{ slug }}>
    window.__CATEGORY_SLUG__ = slug;
  </script>
</BaseLayout>

<script>
async function loadCategory() {
  const slug = window.__CATEGORY_SLUG__;
  const titleEl = document.getElementById('category-title');
  const descEl = document.getElementById('category-description');
  const container = document.getElementById('articles-container');
  if (!container) return;

  try {
    const [categoriesRes, articlesRes] = await Promise.all([
      fetch('/api/categories'),
      fetch('/api/articles'),
    ]);

    const { categories = [] } = await categoriesRes.json();
    const { articles = [] } = await articlesRes.json();

    const category = categories.find((c) => c.slug === slug);
    const filteredArticles = articles.filter((a) => a.category?.slug === slug);

    if (category) {
      document.title = `${category.icon} ${category.name} — news.3mi.ai`;
      if (titleEl) titleEl.textContent = `${category.icon} ${category.name}`;
      if (descEl) descEl.textContent = category.description || '';
    } else {
      if (titleEl) titleEl.textContent = '找不到分類';
    }

    if (filteredArticles.length === 0) {
      container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">這個分類還沒有文章。</div>';
      return;
    }

    container.innerHTML = filteredArticles.map((article) => `
      <a href="/post/${article.slug}" class="card" style="display: block; text-decoration: none; margin-bottom: 16px; padding: 16px;">
        ${article.category ? `<span style="font-size: 12px; color: ${article.category.color};">${article.category.icon} ${article.category.name}</span>` : ''}
        <h3 style="margin: 4px 0; color: var(--text);">${escapeHtml(article.title)}</h3>
        <p style="margin: 0; color: var(--text-secondary); font-size: 14px;">${escapeHtml(article.excerpt || '')}</p>
        <div style="margin-top: 8px; font-size: 12px; color: var(--text-muted);">
          ${article.published_at ? new Date(article.published_at).toLocaleDateString('zh-TW') : ''}
          ${article.reading_time ? ` · ${article.reading_time} 分鐘閱讀` : ''}
        </div>
      </a>
    `).join('');
  } catch (err) {
    console.error('Failed to load category:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

loadCategory();
</script>