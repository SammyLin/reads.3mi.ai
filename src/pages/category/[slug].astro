---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  // Build-time: hardcode known slugs (since D1 binding isn't available)
  // When new categories are added, update this list and redeploy
  return [
    { params: { slug: 'ai' } },
    { params: { slug: 'architecture' } },
    { params: { slug: 'tools' } },
    { params: { slug: 'tutorial' } },
    { params: { slug: 'security' } },
    { params: { slug: 'life' } },
    { params: { slug: 'e2e-testing' } },
  ];
}

const { slug } = Astro.params;
---

<BaseLayout title="分類" description="">
  <header class="collection-header">
    <p class="eyebrow">Channel</p>
    <h1 id="category-title">分類</h1>
    <p id="category-description"></p>
  </header>

  <div id="articles-container">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>

  <script is:inline define:vars={{ slug }}>
    window.__CATEGORY_SLUG__ = slug;
  </script>
</BaseLayout>

<script>
import { categoryIconSvg } from '../../lib/categoryIcon';
import { coverThumb } from '../../lib/cover';

async function loadCategory() {
  const slug = window.__CATEGORY_SLUG__;
  const titleEl = document.getElementById('category-title');
  const descEl = document.getElementById('category-description');
  const container = document.getElementById('articles-container');
  if (!container) return;

  try {
    const pageSize = 10;
    const [categoriesRes, articlesRes] = await Promise.all([
      fetch('/api/categories'),
      fetchCollectionPage(slug, getPageFromUrl(), pageSize),
    ]);

    const { categories = [] } = await categoriesRes.json();
    const { articles = [], pagination = {} } = await articlesRes.json();

    const category = categories.find((c) => c.slug === slug);

    if (category) {
      document.title = `${category.name} — reads.3mi.ai`;
      if (titleEl) titleEl.textContent = `${category.name}`;
      if (descEl) descEl.textContent = `${category.description || ''} 共 ${pagination.total || articles.length} 篇。`;
    } else {
      if (titleEl) titleEl.textContent = '找不到分類';
    }

    if (articles.length === 0) {
      const latestRes = await fetch('/api/articles?limit=6');
      const { articles: latest = [] } = await latestRes.json();
      container.innerHTML = `
        <section class="collection-empty">
          <p class="eyebrow">Coming soon</p>
          <h2>這個頻道正在整理中</h2>
          <p>還沒有歸到這裡的文章。先讀最新發布內容，或從其他頻道開始。</p>
          <a class="collection-empty-action" href="/">瀏覽所有文章</a>
        </section>
        ${latest.length ? `<section class="collection-recommendations"><div class="collection-section-heading"><p class="eyebrow">Latest</p><h2>最新文章</h2></div><div class="collection-list">${latest.map(renderCollectionCard).join('')}</div></section>` : ''}`;
      return;
    }

    renderCollection(slug, articles, pagination, pageSize, container, '分類文章分頁');
  } catch (err) {
    console.error('Failed to load category:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

function fetchCollectionPage(slug, page, limit) {
  return fetch(`/api/articles?category=${encodeURIComponent(slug)}&page=${page}&limit=${limit}`);
}

function renderCollection(slug, articles, pageInfo, pageSize, container, label) {
  const safePage = pageInfo.page || 1;
  const totalPages = pageInfo.totalPages || 1;
  const total = pageInfo.total || articles.length;

  container.innerHTML = `<div class="collection-list">` + articles.map(renderCollectionCard).join('') + `</div>
    <nav class="pagination" id="collection-pagination" aria-label="${label}">${renderPagination(safePage, totalPages, total)}</nav>`;

  const pagination = document.getElementById('collection-pagination');
  if (pagination) {
    bindPagination(pagination, async (nextPage) => {
      setPageInUrl(nextPage);
      const res = await fetchCollectionPage(slug, nextPage, pageSize);
      const data = await res.json();
      renderCollection(slug, data.articles || [], data.pagination || {}, pageSize, container, label);
    });
  }
}

function renderCollectionCard(article) {
  return `
    <a href="/post/${article.slug}" class="collection-card">
      <div class="collection-card-body">
        <div class="collection-card-meta">
          ${article.category ? `<span style="color: ${article.category.color}; display: inline-flex; align-items: center; gap: 4px;">${categoryIconSvg(article.category.slug)} ${escapeHtml(article.category.name)}</span>` : ''}
          <time>${article.published_at ? new Date(article.published_at).toLocaleDateString('zh-TW') : ''}</time>
          <span>${article.reading_time || 1} 分鐘</span>
        </div>
        <h3>${escapeHtml(article.title)}</h3>
        <p>${escapeHtml(article.excerpt || '')}</p>
      </div>
      ${coverThumb(article, 'card-thumb collection-thumb')}
    </a>`;
}

function renderPagination(page, totalPages, totalItems) {
  if (totalPages <= 1) return `<span class="pagination-summary">共 ${totalItems} 篇</span>`;
  const pages = [];
  const start = Math.max(1, page - 2);
  const end = Math.min(totalPages, page + 2);
  for (let i = start; i <= end; i++) {
    pages.push(`<button type="button" data-page="${i}" ${i === page ? 'class="active" aria-current="page"' : ''}>${i}</button>`);
  }
  return `
    <button type="button" data-page="${Math.max(1, page - 1)}" ${page === 1 ? 'disabled' : ''}>上一頁</button>
    ${pages.join('')}
    <button type="button" data-page="${Math.min(totalPages, page + 1)}" ${page === totalPages ? 'disabled' : ''}>下一頁</button>
    <span class="pagination-summary">第 ${page}/${totalPages} 頁 · 共 ${totalItems} 篇</span>`;
}

function bindPagination(container, onPage) {
  container.querySelectorAll('button[data-page]').forEach((button) => {
    button.addEventListener('click', () => {
      const nextPage = Number(button.getAttribute('data-page'));
      if (Number.isFinite(nextPage)) onPage(nextPage);
    });
  });
}

function getPageFromUrl() {
  const page = Number(new URL(window.location.href).searchParams.get('page') || '1');
  return Number.isFinite(page) && page > 0 ? Math.floor(page) : 1;
}

function setPageInUrl(page) {
  const url = new URL(window.location.href);
  url.searchParams.set('page', String(page));
  window.history.replaceState({}, '', url);
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

loadCategory();
</script>
