---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDB, getArticleBySlug } from '../../lib/db';
import { extractFirstImage } from '../../lib/ogImage';

export const prerender = false;

const { slug } = Astro.params;

let ogArticle: any = null;
try {
  const db = getDB(Astro);
  ogArticle = slug ? await getArticleBySlug(db, slug) : null;
} catch (e) {
  console.error(e);
}
if (!ogArticle || ogArticle.status !== 'published') return Astro.redirect('/404');

// og:image 優先序：真封面 > 第一張內文圖 > 自動品牌封面（path 版 SVG，中文安全）
const isGeneratedCover = String(ogArticle.cover_image || '').startsWith('/api/og');
const rawCover = (!isGeneratedCover && ogArticle.cover_image)
  || extractFirstImage(ogArticle.content_md)
  || (ogArticle.cover_image ? `${ogArticle.cover_image}&pv=2` : '/og-default.png');
const ogImage = new URL(rawCover, Astro.url.origin).toString();
---

<BaseLayout
  title={ogArticle.title}
  description={(ogArticle.excerpt || '').slice(0, 200)}
  ogImage={ogImage}
  showSidebars={false}
>
  <article id="article-container">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </article>

  <script is:inline define:vars={{ slug }}>
    window.__ARTICLE_SLUG__ = slug;
  </script>
</BaseLayout>

<script>
async function loadArticle() {
  const slug = window.__ARTICLE_SLUG__;
  const container = document.getElementById('article-container');
  if (!container) return;

  try {
    const res = await fetch(`/api/articles?slug=${encodeURIComponent(slug)}`);
    if (!res.ok) {
      window.location.href = '/404';
      return;
    }
    const data = await res.json();

    if (!data.article) {
      window.location.href = '/404';
      return;
    }

    const article = data.article;
    document.title = `${article.title} — news.3mi.ai`;

    // 瀏覽數 +1（fire-and-forget，不擋渲染）
    try {
      fetch(`/api/view?slug=${encodeURIComponent(slug)}`, { method: 'POST', keepalive: true });
    } catch (_) { /* ignore */ }
    const dateStr = article.published_at ? new Date(article.published_at).toISOString().slice(0, 10) : '';
    const sourceLabel = article.source_type ? escapeHtml(article.source_type) : '本站筆記';

    container.innerHTML = `
      <div class="reading-progress" aria-hidden="true"><span id="reading-progress-bar"></span></div>
      <article class="prose article-shell">
        <header class="article-header">
          <div class="article-kicker">
            <span class="decision-badge decision-${article.decision_status || 'watch'}">${({adopt:'Adopt',trial:'Trial',watch:'Watch',avoid:'Avoid'})[article.decision_status] || 'Watch'}</span>
            <span class="text-muted">${article.content_type || 'signal'}</span>
            <span class="text-muted">Impact ${article.impact_level || 'medium'}</span>
            <span class="text-muted">Confidence ${article.confidence ?? 70}%</span>
            ${article.category ? `<a href="/category/${article.category.slug}" class="tag" style="background: ${article.category.color}22; color: ${article.category.color}; border-bottom: none;">${article.category.name}</a>` : ''}
            <time class="text-muted">${dateStr}</time>
            <span class="text-muted">${article.reading_time} 分鐘閱讀</span>
            <span class="text-muted">${sourceLabel}</span>
          </div>
          <h1>${escapeHtml(article.title)}</h1>
          ${article.excerpt ? `<p style="font-size: 16px; color: var(--text-secondary); margin-top: 12px;">${escapeHtml(article.excerpt)}</p>` : ''}
          <div class="article-actions">
            ${isHttpUrl(article.source_url) ? `<a class="source-card" href="${escapeAttr(article.source_url)}" target="_blank" rel="noopener"><span>原文來源</span><strong>${sourceLabel}</strong></a>` : ''}
            ${isHttpUrl(article.related_chunk_url) ? `<a class="source-card" href="${escapeAttr(article.related_chunk_url)}" target="_blank" rel="noopener"><span>延伸練習 · ChunkUp</span><strong>${escapeHtml(article.related_chunk_title || '練習相關英文語塊')}</strong></a>` : ''}
            <a class="source-card" href="/archive"><span>返回</span><strong>文章存檔</strong></a>
          </div>
        </header>

        ${article.cover_image ? `<img src="${escapeHtml(article.cover_image)}" alt="${escapeHtml(article.title)}" style="margin-bottom: 32px; border-radius: var(--radius-lg); max-width: 100%;" />` : ''}

        <div class="markdown-content">${article.content_html || '<p>內容待補。</p>'}</div>

        ${(article.tags && article.tags.length > 0) ? `
          <footer style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border);">
            <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
              <span class="text-muted" style="font-size: 13px; font-weight: 600;">標籤</span>
              ${article.tags.map((tag) => `<a href="/tag/${tag.slug}" class="tag" style="border-bottom: none;">#${escapeHtml(tag.name)}</a>`).join('')}
            </div>
          </footer>` : ''}

        <aside class="article-subscribe">
          <div>
            <strong>追蹤後續整理</strong>
            <p>用 RSS 接收 AI 工程訊號、工具觀察與架構筆記。</p>
          </div>
          <a href="/rss.xml">RSS Feed</a>
        </aside>
      </article>`;

    const progressBar = document.getElementById('reading-progress-bar');
    if (progressBar) {
      const updateProgress = () => {
        const doc = document.documentElement;
        const max = doc.scrollHeight - doc.clientHeight;
        const pct = max > 0 ? Math.min(100, Math.max(0, (doc.scrollTop / max) * 100)) : 0;
        progressBar.style.width = `${pct}%`;
      };
      updateProgress();
      window.addEventListener('scroll', updateProgress, { passive: true });
    }
  } catch (err) {
    console.error('Failed to load article:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeAttr(s) {
  return escapeHtml(s).replace(/`/g, '&#96;');
}

function isHttpUrl(s) {
  return typeof s === 'string' && /^https?:\/\//i.test(s.trim());
}

loadArticle();
</script>
