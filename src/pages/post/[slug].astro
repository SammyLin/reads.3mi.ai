---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDB } from '../../lib/db';

export async function getStaticPaths() {
  // Build-time: hardcode known article slugs
  // Update when new articles are published
  return [
    { params: { slug: 'welcome-to-news-3mi' } },
    { params: { slug: 'building-news-3mi-with-ai-agents' } },
    { params: { slug: 'why-i-chose-astro-over-nextjs' } },
    { params: { slug: 'obsidian-cli-obsidian-from-terminal' } },
    { params: { slug: 'cloudflare-d1-from-zero-to-prod' } },
    { params: { slug: 'api-token-rotation-pain' } },
    { params: { slug: 'why-i-started-news-3mi' } },
  ];
}

const { slug } = Astro.params;
---

<BaseLayout title="文章" description="">
  <article id="article-container">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </article>

  <script is:inline define:vars={{ slug }}>
    window.__ARTICLE_SLUG__ = slug;
  </script>
</BaseLayout>

<script>
async function loadArticle() {
  const slug = window.__ARTICLE_SLUG__;
  const container = document.getElementById('article-container');
  if (!container) return;

  try {
    const res = await fetch(`/api/articles?slug=${encodeURIComponent(slug)}`);
    if (!res.ok) {
      window.location.href = '/404';
      return;
    }
    const data = await res.json();

    if (!data.article) {
      window.location.href = '/404';
      return;
    }

    const article = data.article;
    document.title = `${article.title} — news.3mi.ai`;
    const dateStr = article.published_at ? new Date(article.published_at).toISOString().slice(0, 10) : '';

    container.innerHTML = `
      <article class="prose">
        <header style="margin-bottom: 32px; padding-bottom: 16px; border-bottom: 1px solid var(--border);">
          <div style="display: flex; gap: 12px; align-items: center; font-size: 13px; margin-bottom: 12px; flex-wrap: wrap;">
            ${article.category ? `<a href="/category/${article.category.slug}" class="tag" style="background: ${article.category.color}22; color: ${article.category.color}; text-decoration: none;">${article.category.icon} ${article.category.name}</a>` : ''}
            <span class="text-muted">·</span>
            <time class="text-muted">${dateStr}</time>
            <span class="text-muted">·</span>
            <span class="text-muted">${article.reading_time} 分鐘閱讀</span>
            <span class="text-muted">·</span>
            <span class="text-muted">👁 ${article.view_count}</span>
          </div>
          <h1 style="font-size: 36px; line-height: 1.3;">${escapeHtml(article.title)}</h1>
          ${article.excerpt ? `<p style="font-size: 16px; color: var(--text-secondary); margin-top: 12px;">${escapeHtml(article.excerpt)}</p>` : ''}
        </header>

        ${article.cover_image ? `<img src="${escapeHtml(article.cover_image)}" alt="${escapeHtml(article.title)}" style="margin-bottom: 32px; border-radius: var(--radius-lg); max-width: 100%;" />` : ''}

        <div class="markdown-content">${article.content_html || '<p>內容待補。</p>'}</div>

        ${(article.tags && article.tags.length > 0) ? `
          <footer style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border);">
            <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
              <span class="text-muted" style="font-size: 13px;">🏷 標籤：</span>
              ${article.tags.map((tag) => `<a href="/tag/${tag.slug}" class="tag" style="text-decoration: none;">#${escapeHtml(tag.name)}</a>`).join('')}
            </div>
          </footer>` : ''}
      </article>`;
  } catch (err) {
    console.error('Failed to load article:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

loadArticle();
</script>