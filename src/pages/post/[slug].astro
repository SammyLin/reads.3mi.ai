---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDB, getArticleBySlug } from '../../lib/db';
import { extractFirstImage } from '../../lib/ogImage';

export const prerender = false;

const { slug } = Astro.params;

let ogArticle: any = null;
try {
  const db = getDB(Astro);
  ogArticle = slug ? await getArticleBySlug(db, slug) : null;
} catch (e) {
  console.error(e);
}
if (!ogArticle || ogArticle.status !== 'published') return Astro.redirect('/404');

// og:image 優先序：真封面 > 第一張內文圖 > 自動品牌封面（path 版 SVG，中文安全）
const isGeneratedCover = String(ogArticle.cover_image || '').startsWith('/api/og');
const rawCover = (!isGeneratedCover && ogArticle.cover_image)
  || extractFirstImage(ogArticle.content_md)
  || (ogArticle.cover_image ? `${ogArticle.cover_image}&pv=2` : '/og-default.png');
const ogImage = new URL(rawCover, Astro.url.origin).toString();
---

<BaseLayout
  title={ogArticle.title}
  description={(ogArticle.excerpt || '').slice(0, 200)}
  ogImage={ogImage}
  showSidebars={false}
>
  <article id="article-container">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </article>

  <script is:inline define:vars={{ slug }}>
    window.__ARTICLE_SLUG__ = slug;
  </script>

  <style is:global>
    /* 目錄搬到側邊(.is-split)時,外層 container 也要放寬,避免側欄被裁切或擠壓內文 */
    body:has(#article-layout.is-split) main.container { max-width: 1160px; }
  </style>
</BaseLayout>

<script>
// lucide inline SVG（runtime 組字串，UI 不用 emoji）
const LUCIDE_ICONS = {
  'pen-line': '<path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/>',
  sparkles: '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>',
  languages: '<path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/>',
  list: '<path d="M3 12h.01"/><path d="M3 18h.01"/><path d="M3 6h.01"/><path d="M8 12h13"/><path d="M8 18h13"/><path d="M8 6h13"/>',
};

function lucide(name) {
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${LUCIDE_ICONS[name] || ''}</svg>`;
}

const AUTHORSHIP = {
  original: { label: '觀點', icon: 'pen-line' },
  ai: { label: 'AI 精選', icon: 'sparkles' },
  translation: { label: '譯文', icon: 'languages' },
};

// 英文語塊練習：從 ChunkUp 公開 feed 拉本文對應課程的語塊,像推薦文章一樣一個區塊
async function loadChunkPractice(article) {
  const body = document.getElementById('chunk-practice-body');
  if (!body) return;
  const url = article.related_chunk_url;
  const fallback = `<a class="source-card" href="${escapeAttr(url)}" target="_blank" rel="noopener"><span>ChunkUp</span><strong>${escapeHtml(article.related_chunk_title || '練習相關英文語塊')}</strong></a>`;
  try {
    const res = await fetch('https://chunkup.3mi.ai/content-feed.json');
    const feed = await res.json();
    const norm = (u) => String(u || '').replace(/\/+$/, '');
    const item = (feed.items || []).find((it) => norm(it.url) === norm(url));
    if (!item || !(item.chunks || []).length) { body.innerHTML = fallback; return; }
    body.innerHTML = `
      <div class="chunk-practice-grid">${item.chunks.slice(0, 6).map((c) => `
        <a class="chunk-pill" href="${escapeAttr(item.url)}" target="_blank" rel="noopener">
          <strong>${escapeHtml(c.text)}</strong>
          <span>${escapeHtml(c.gloss || c.function || '')}</span>
        </a>`).join('')}
      </div>
      <a class="source-card" style="margin-top: 16px;" href="${escapeAttr(item.url)}" target="_blank" rel="noopener"><span>ChunkUp · 免費</span><strong>去練這課：${escapeHtml(item.title)} — 聽發音、跟讀、影片逐句跳播</strong></a>`;
  } catch { body.innerHTML = fallback; }
}

// 推薦文章：同分類優先，不足補最新，排除當前文章
async function loadRelated(article) {
  const section = document.getElementById('related-posts');
  const grid = document.getElementById('related-grid');
  if (!section || !grid) return;

  try {
    const exclude = `exclude=${encodeURIComponent(article.slug)}&limit=4`;
    let related = [];
    if (article.category?.slug) {
      const res = await fetch(`/api/articles?category=${encodeURIComponent(article.category.slug)}&${exclude}`);
      const data = await res.json();
      related = data.articles || [];
    }
    if (related.length < 4) {
      const res = await fetch(`/api/articles?${exclude}`);
      const data = await res.json();
      const seen = new Set(related.map((a) => a.slug));
      for (const a of data.articles || []) {
        if (related.length >= 4) break;
        if (!seen.has(a.slug)) { related.push(a); seen.add(a.slug); }
      }
    }
    if (related.length === 0) return;

    grid.innerHTML = related.map((a) => {
      const auth = AUTHORSHIP[a.authorship] || AUTHORSHIP.ai;
      const date = a.published_at ? new Date(a.published_at).toISOString().slice(0, 10) : '';
      return `
        <a href="/post/${encodeURIComponent(a.slug)}" class="related-card">
          <div class="related-meta">
            <span class="authorship-badge authorship-${a.authorship || 'ai'}">${lucide(auth.icon)}${auth.label}</span>
            ${a.category ? `<span style="color: ${escapeAttr(a.category.color)}; font-weight: 600;">${escapeHtml(a.category.name)}</span>` : ''}
            <span>${date}</span>
          </div>
          <h3>${escapeHtml(a.title)}</h3>
          ${a.excerpt ? `<p>${escapeHtml(a.excerpt)}</p>` : ''}
        </a>`;
    }).join('');
    section.hidden = false;
  } catch (err) {
    console.error('Failed to load related articles:', err);
  }
}

async function loadArticle() {
  const slug = window.__ARTICLE_SLUG__;
  const container = document.getElementById('article-container');
  if (!container) return;

  try {
    const res = await fetch(`/api/articles?slug=${encodeURIComponent(slug)}`);
    if (!res.ok) {
      window.location.href = '/404';
      return;
    }
    const data = await res.json();

    if (!data.article) {
      window.location.href = '/404';
      return;
    }

    const article = data.article;
    document.title = `${article.title} — reads.3mi.ai`;

    // 瀏覽數 +1（fire-and-forget，不擋渲染）
    try {
      fetch(`/api/view?slug=${encodeURIComponent(slug)}`, { method: 'POST', keepalive: true });
    } catch (_) { /* ignore */ }
    const dateStr = article.published_at ? new Date(article.published_at).toISOString().slice(0, 10) : '';
    const sourceLabel = article.source_type ? escapeHtml(article.source_type) : '本站筆記';
    const authorship = AUTHORSHIP[article.authorship] || AUTHORSHIP.ai;

    // 譯文：文首標明原文出處；AI / 譯文：文末揭露一行
    const translationNote = article.authorship === 'translation' && isHttpUrl(article.source_url)
      ? `<div class="authorship-note">${lucide(authorship.icon)}<span>本文翻譯自 <a href="${escapeAttr(article.source_url)}" target="_blank" rel="noopener">${sourceLabel}</a> 的原文，著作權屬原作者；譯文僅供參考，請以原文為準。</span></div>`
      : '';
    const disclosure = article.authorship === 'ai'
      ? `<div class="authorship-disclosure">${lucide(AUTHORSHIP.ai.icon)}<span>本文由 AI 整理撰寫，經山米挑選與確認後發佈。</span></div>`
      : article.authorship === 'translation'
        ? `<div class="authorship-disclosure">${lucide(AUTHORSHIP.translation.icon)}<span>本文為原文翻譯，非本站原創觀點。</span></div>`
        : '';

    container.innerHTML = `
      <div class="reading-progress" aria-hidden="true"><span id="reading-progress-bar"></span></div>
      <div class="article-layout" id="article-layout">
      <article class="prose article-shell">
        <header class="article-header">
          <div class="article-kicker">
            <span class="authorship-badge authorship-${article.authorship || 'ai'}">${lucide(authorship.icon)}${authorship.label}</span>
            <span class="decision-badge decision-${article.decision_status || 'watch'}">${({adopt:'Adopt',trial:'Trial',watch:'Watch',avoid:'Avoid'})[article.decision_status] || 'Watch'}</span>
            <span class="text-muted">${article.content_type || 'signal'}</span>
            <span class="text-muted">Impact ${article.impact_level || 'medium'}</span>
            <span class="text-muted">Confidence ${article.confidence ?? 70}%</span>
            ${article.category ? `<a href="/category/${article.category.slug}" class="tag" style="background: ${article.category.color}22; color: ${article.category.color}; border-bottom: none;">${article.category.name}</a>` : ''}
            <time class="text-muted">${dateStr}</time>
            <span class="text-muted">${article.reading_time} 分鐘閱讀</span>
            <span class="text-muted">${sourceLabel}</span>
          </div>
          <h1>${escapeHtml(article.title)}</h1>
          ${article.excerpt ? `<p style="font-size: 16px; color: var(--text-secondary); margin-top: 12px;">${escapeHtml(article.excerpt)}</p>` : ''}
          <div class="article-actions">
            ${isHttpUrl(article.source_url) ? `<a class="source-card" href="${escapeAttr(article.source_url)}" target="_blank" rel="noopener"><span>原文來源</span><strong>${sourceLabel}</strong></a>` : ''}
            <a class="source-card" href="/archive"><span>返回</span><strong>文章存檔</strong></a>
          </div>
        </header>

        ${article.cover_image ? `<img src="${escapeHtml(article.cover_image)}" alt="${escapeHtml(article.title)}" style="margin-bottom: 32px; border-radius: var(--radius-lg); max-width: 100%;" />` : ''}

        ${translationNote}

        <nav class="article-toc" id="article-toc" hidden aria-label="目錄"><strong>${lucide('list')}文章目錄</strong><ul id="article-toc-list"></ul></nav>

        <div class="markdown-content" id="markdown-content">${article.content_html || '<p>內容待補。</p>'}</div>

        ${disclosure}

        ${(article.tags && article.tags.length > 0) ? `
          <footer style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border);">
            <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
              <span class="text-muted" style="font-size: 13px; font-weight: 600;">標籤</span>
              ${article.tags.map((tag) => `<a href="/tag/${tag.slug}" class="tag" style="border-bottom: none;">#${escapeHtml(tag.name)}</a>`).join('')}
            </div>
          </footer>` : ''}

        ${isHttpUrl(article.related_chunk_url) ? `
        <section class="related-posts" id="chunk-practice">
          <h2>英文語塊練習</h2>
          <div id="chunk-practice-body"></div>
        </section>` : ''}

        <section class="related-posts" id="related-posts" hidden>
          <h2>推薦文章</h2>
          <div class="related-grid" id="related-grid"></div>
        </section>

      </article>
      </div>`;

    buildToc();
    loadChunkPractice(article);
    loadRelated(article);

    const progressBar = document.getElementById('reading-progress-bar');
    if (progressBar) {
      const updateProgress = () => {
        const doc = document.documentElement;
        const max = doc.scrollHeight - doc.clientHeight;
        const pct = max > 0 ? Math.min(100, Math.max(0, (doc.scrollTop / max) * 100)) : 0;
        progressBar.style.width = `${pct}%`;
      };
      updateProgress();
      window.addEventListener('scroll', updateProgress, { passive: true });
    }
  } catch (err) {
    console.error('Failed to load article:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

// 目錄：從 markdown-content 的 h2/h3 產生錨點清單,點擊平滑捲動
function slugifyHeading(text) {
  const slug = (text || '').trim().toLowerCase()
    .replace(/[^\p{L}\p{N}]+/gu, '-')
    .replace(/^-+|-+$/g, '');
  return slug || 'section';
}

function buildToc() {
  const layout = document.getElementById('article-layout');
  const shell = document.querySelector('.article-shell');
  const toc = document.getElementById('article-toc');
  const list = document.getElementById('article-toc-list');
  const content = document.getElementById('markdown-content');
  if (!layout || !shell || !toc || !list || !content) return;

  const headings = Array.from(content.querySelectorAll('h2, h3'));
  if (headings.length < 2) return;

  const used = new Set();
  const items = headings.map((h) => {
    let id = slugifyHeading(h.textContent);
    if (used.has(id)) {
      let i = 2;
      while (used.has(`${id}-${i}`)) i++;
      id = `${id}-${i}`;
    }
    used.add(id);
    h.id = id;
    return { id, text: h.textContent || '', level: h.tagName === 'H3' ? 3 : 2 };
  });

  list.innerHTML = items.map((it) =>
    `<li class="toc-level-${it.level}"><a href="#${it.id}">${escapeHtml(it.text)}</a></li>`
  ).join('');
  toc.hidden = false;

  list.addEventListener('click', (e) => {
    const a = e.target.closest('a');
    if (!a) return;
    const id = a.getAttribute('href').slice(1);
    const target = document.getElementById(id);
    if (!target) return;
    e.preventDefault();
    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    history.pushState(null, '', `#${id}`);
  });

  // 右側留白夠寬才把目錄搬到側邊(sticky 跟著捲動),不夠就放回內文原位,絕不擠壓內文寬度
  const positionToc = () => {
    const shellWidth = shell.getBoundingClientRect().width || shell.offsetWidth;
    const gap = 56;
    const railWidth = 240;
    const shouldFloat = window.innerWidth >= shellWidth + gap + railWidth + 160;
    const isFloating = layout.classList.contains('is-split');
    if (shouldFloat && !isFloating) {
      layout.classList.add('is-split');
      layout.appendChild(toc);
    } else if (!shouldFloat && isFloating) {
      layout.classList.remove('is-split');
      shell.insertBefore(toc, content);
    }
  };
  positionToc();
  window.addEventListener('resize', positionToc);
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeAttr(s) {
  return escapeHtml(s).replace(/`/g, '&#96;');
}

function isHttpUrl(s) {
  return typeof s === 'string' && /^https?:\/\//i.test(s.trim());
}

loadArticle();
</script>
