---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="所有文章" description="所有文章列表">
  <header style="margin-bottom: 32px; padding-bottom: 16px; border-bottom: 1px solid var(--border);">
    <h1 style="font-size: 28px;">📚 所有文章</h1>
    <p class="text-secondary" style="margin-top: 8px;">共 <span id="article-count">...</span> 篇</p>
  </header>

  <div id="archive-content">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>
</BaseLayout>

<script>
async function loadArchive() {
  const container = document.getElementById('archive-content');
  const countEl = document.getElementById('article-count');
  if (!container) return;

  try {
    const res = await fetch('/api/articles');
    const { articles = [] } = await res.json();

    if (countEl) countEl.textContent = String(articles.length);
    if (articles.length === 0) {
      container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">還沒有文章。</div>';
      return;
    }

    // Group by year
    const byYear: Record<string, typeof articles> = {};
    for (const article of articles) {
      const year = article.published_at
        ? new Date(article.published_at).getFullYear().toString()
        : 'unknown';
      if (!byYear[year]) byYear[year] = [];
      byYear[year].push(article);
    }
    const years = Object.keys(byYear).sort((a, b) => b.localeCompare(a));

    container.innerHTML = years.map(year => `
      <section style="margin-bottom: 32px;">
        <h2 style="font-size: 20px; font-weight: 700; color: var(--accent); margin-bottom: 16px;">${year}</h2>
        ${byYear[year].map(article => `
          <a href="/post/${article.slug}" class="card" style="display: block; text-decoration: none; margin-bottom: 12px; padding: 16px;">
            ${article.category ? `<span style="font-size: 12px; color: ${article.category.color};">${article.category.icon} ${article.category.name}</span>` : ''}
            <h3 style="margin: 4px 0; color: var(--text);">${article.title}</h3>
            <p style="margin: 0; color: var(--text-secondary); font-size: 14px;">${article.excerpt || ''}</p>
            <div style="margin-top: 8px; font-size: 12px; color: var(--text-muted);">
              ${article.published_at ? new Date(article.published_at).toLocaleDateString('zh-TW') : ''}
              ${article.reading_time ? ` · ${article.reading_time} 分鐘閱讀` : ''}
            </div>
          </a>
        `).join('')}
      </section>
    `).join('');
  } catch (err) {
    console.error('Failed to load archive:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

loadArchive();
</script>
