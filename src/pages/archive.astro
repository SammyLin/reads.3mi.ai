---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="文章存檔" description="所有文章列表">
  <header class="collection-header">
    <p class="eyebrow">Archive</p>
    <h1>文章存檔</h1>
    <p>按時間整理全部 AI 工程筆記與 OpenClaw 來源摘要，共 <span id="article-count">...</span> 篇。</p>
  </header>

  <div class="authorship-tabs" id="authorship-tabs" role="tablist" aria-label="依作者身分過濾" style="margin: 0 0 20px;"></div>

  <div id="archive-content">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>
</BaseLayout>

<script>
import { categoryIconSvg } from '../lib/categoryIcon';
import { coverThumb } from '../lib/cover';

// lucide inline SVG（runtime 組字串，UI 不用 emoji）
const LUCIDE_ICONS = {
  'pen-line': '<path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/>',
  sparkles: '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>',
  languages: '<path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/>',
};

function lucide(name) {
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${LUCIDE_ICONS[name] || ''}</svg>`;
}

const AUTHORSHIP = {
  original: { label: '觀點', icon: 'pen-line' },
  ai: { label: 'AI 精選', icon: 'sparkles' },
  translation: { label: '譯文', icon: 'languages' },
};

function getAuthorshipFromUrl() {
  const value = new URL(window.location.href).searchParams.get('authorship');
  return value && AUTHORSHIP[value] ? value : '';
}

async function loadArchive() {
  const container = document.getElementById('archive-content');
  const countEl = document.getElementById('article-count');
  if (!container) return;

  const pageSize = 10;
  renderAuthorshipTabs(pageSize, container, countEl);

  try {
    const res = await fetchArchivePage(getPageFromUrl(), pageSize);
    const { articles = [], pagination = {} } = await res.json();

    if (countEl) countEl.textContent = String(pagination.total || articles.length);
    if (articles.length === 0) {
      container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">還沒有文章。</div>';
      return;
    }

    renderArchive(articles, pagination, pageSize, container);
  } catch (err) {
    console.error('Failed to load archive:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

function fetchArchivePage(page, limit) {
  const authorship = getAuthorshipFromUrl();
  const filter = authorship ? `&authorship=${authorship}` : '';
  return fetch(`/api/articles?page=${page}&limit=${limit}${filter}`);
}

function renderAuthorshipTabs(pageSize, container, countEl) {
  const tabs = document.getElementById('authorship-tabs');
  if (!tabs) return;
  const active = getAuthorshipFromUrl();

  tabs.innerHTML = [
    `<button type="button" data-authorship="" ${active === '' ? 'class="active"' : ''}>全部</button>`,
    ...Object.entries(AUTHORSHIP).map(([key, meta]) =>
      `<button type="button" data-authorship="${key}" ${active === key ? 'class="active"' : ''}>${lucide(meta.icon)}${meta.label}</button>`
    ),
  ].join('');

  tabs.querySelectorAll('button[data-authorship]').forEach((button) => {
    button.addEventListener('click', async () => {
      const url = new URL(window.location.href);
      const value = button.getAttribute('data-authorship');
      if (value) url.searchParams.set('authorship', value);
      else url.searchParams.delete('authorship');
      url.searchParams.delete('page');
      window.history.replaceState({}, '', url);

      tabs.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === button));
      const res = await fetchArchivePage(1, pageSize);
      const data = await res.json();
      if (countEl) countEl.textContent = String(data.pagination?.total ?? (data.articles || []).length);
      renderArchive(data.articles || [], data.pagination || {}, pageSize, container);
    });
  });
}

function renderArchive(articles, pageInfo, pageSize, container) {
  const safePage = pageInfo.page || 1;
  const totalPages = pageInfo.totalPages || 1;
  const total = pageInfo.total || articles.length;

  // Group the current page by year, so the archive stays readable after pagination.
  const byYear = {};
  for (const article of articles) {
    const year = article.published_at
      ? new Date(article.published_at).getFullYear().toString()
      : 'unknown';
    if (!byYear[year]) byYear[year] = [];
    byYear[year].push(article);
  }
  const years = Object.keys(byYear).sort((a, b) => b.localeCompare(a));

  container.innerHTML = years.map(year => `
    <section class="archive-year">
      <h2>${year}</h2>
      <div>
        ${byYear[year].map(article => `
          <a href="/post/${article.slug}" class="collection-card">
            <div class="collection-card-body">
              <div class="collection-card-meta">
                <span class="authorship-badge authorship-${article.authorship || 'ai'}">${lucide((AUTHORSHIP[article.authorship] || AUTHORSHIP.ai).icon)}${(AUTHORSHIP[article.authorship] || AUTHORSHIP.ai).label}</span>
                ${article.category ? `<span style="color: ${article.category.color}; display: inline-flex; align-items: center; gap: 4px;">${categoryIconSvg(article.category.slug)} ${escapeHtml(article.category.name)}</span>` : ''}
                <time>${article.published_at ? new Date(article.published_at).toLocaleDateString('zh-TW') : ''}</time>
                <span>${article.reading_time || 1} 分鐘</span>
              </div>
              <h3>${escapeHtml(article.title)}</h3>
              <p>${escapeHtml(article.excerpt || '')}</p>
            </div>
            ${coverThumb(article, 'card-thumb collection-thumb')}
          </a>
        `).join('')}
      </div>
    </section>
  `).join('') + `<nav class="pagination" id="archive-pagination" aria-label="文章存檔分頁">${renderPagination(safePage, totalPages, total)}</nav>`;

  const pagination = document.getElementById('archive-pagination');
  if (pagination) {
    bindPagination(pagination, async (nextPage) => {
      setPageInUrl(nextPage);
      const res = await fetchArchivePage(nextPage, pageSize);
      const data = await res.json();
      renderArchive(data.articles || [], data.pagination || {}, pageSize, container);
    });
  }
}

function renderPagination(page, totalPages, totalItems) {
  if (totalPages <= 1) return `<span class="pagination-summary">共 ${totalItems} 篇</span>`;
  const pages = [];
  for (let i = 1; i <= totalPages; i++) {
    pages.push(`<button type="button" data-page="${i}" ${i === page ? 'class="active" aria-current="page"' : ''}>${i}</button>`);
  }
  return `
    <button type="button" data-page="${Math.max(1, page - 1)}" ${page === 1 ? 'disabled' : ''}>上一頁</button>
    ${pages.join('')}
    <button type="button" data-page="${Math.min(totalPages, page + 1)}" ${page === totalPages ? 'disabled' : ''}>下一頁</button>
    <span class="pagination-summary">第 ${page}/${totalPages} 頁 · 共 ${totalItems} 篇</span>`;
}

function bindPagination(container, onPage) {
  container.querySelectorAll('button[data-page]').forEach((button) => {
    button.addEventListener('click', () => {
      const nextPage = Number(button.getAttribute('data-page'));
      if (Number.isFinite(nextPage)) onPage(nextPage);
    });
  });
}

function getPageFromUrl() {
  const page = Number(new URL(window.location.href).searchParams.get('page') || '1');
  return Number.isFinite(page) && page > 0 ? Math.floor(page) : 1;
}

function setPageInUrl(page) {
  const url = new URL(window.location.href);
  url.searchParams.set('page', String(page));
  window.history.replaceState({}, '', url);
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

loadArchive();
</script>
