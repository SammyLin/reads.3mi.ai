---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="文章存檔" description="所有文章列表">
  <header class="collection-header">
    <p class="eyebrow">Archive</p>
    <h1>文章存檔</h1>
    <p>按時間整理全部 AI 工程筆記與 OpenClaw 來源摘要，共 <span id="article-count">...</span> 篇。</p>
  </header>

  <div id="archive-content">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>
</BaseLayout>

<script>
async function loadArchive() {
  const container = document.getElementById('archive-content');
  const countEl = document.getElementById('article-count');
  if (!container) return;

  try {
    const res = await fetch('/api/articles');
    const { articles = [] } = await res.json();

    if (countEl) countEl.textContent = String(articles.length);
    if (articles.length === 0) {
      container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">還沒有文章。</div>';
      return;
    }

    renderArchive(articles, getPageFromUrl(), 10, container);
  } catch (err) {
    console.error('Failed to load archive:', err);
    container.innerHTML = '<div class="card text-secondary" style="padding: 40px; text-align: center;">載入失敗。</div>';
  }
}

function renderArchive(articles, page, pageSize, container) {
  const totalPages = Math.max(1, Math.ceil(articles.length / pageSize));
  const safePage = Math.min(Math.max(page, 1), totalPages);
  const start = (safePage - 1) * pageSize;
  const pageArticles = articles.slice(start, start + pageSize);

  // Group the current page by year, so the archive stays readable after pagination.
  const byYear = {};
  for (const article of pageArticles) {
    const year = article.published_at
      ? new Date(article.published_at).getFullYear().toString()
      : 'unknown';
    if (!byYear[year]) byYear[year] = [];
    byYear[year].push(article);
  }
  const years = Object.keys(byYear).sort((a, b) => b.localeCompare(a));

  container.innerHTML = years.map(year => `
    <section class="archive-year">
      <h2>${year}</h2>
      <div>
        ${byYear[year].map(article => `
          <a href="/post/${article.slug}" class="collection-card">
            <div class="collection-card-meta">
              ${article.category ? `<span style="color: ${article.category.color};">${article.category.icon || ''} ${escapeHtml(article.category.name)}</span>` : ''}
              <time>${article.published_at ? new Date(article.published_at).toLocaleDateString('zh-TW') : ''}</time>
              <span>${article.reading_time || 1} 分鐘</span>
            </div>
            <h3>${escapeHtml(article.title)}</h3>
            <p>${escapeHtml(article.excerpt || '')}</p>
          </a>
        `).join('')}
      </div>
    </section>
  `).join('') + `<nav class="pagination" id="archive-pagination" aria-label="文章存檔分頁">${renderPagination(safePage, totalPages, articles.length)}</nav>`;

  const pagination = document.getElementById('archive-pagination');
  if (pagination) {
    bindPagination(pagination, (nextPage) => {
      setPageInUrl(nextPage);
      renderArchive(articles, nextPage, pageSize, container);
    });
  }
}

function renderPagination(page, totalPages, totalItems) {
  if (totalPages <= 1) return `<span class="pagination-summary">共 ${totalItems} 篇</span>`;
  const pages = [];
  for (let i = 1; i <= totalPages; i++) {
    pages.push(`<button type="button" data-page="${i}" ${i === page ? 'class="active" aria-current="page"' : ''}>${i}</button>`);
  }
  return `
    <button type="button" data-page="${Math.max(1, page - 1)}" ${page === 1 ? 'disabled' : ''}>上一頁</button>
    ${pages.join('')}
    <button type="button" data-page="${Math.min(totalPages, page + 1)}" ${page === totalPages ? 'disabled' : ''}>下一頁</button>
    <span class="pagination-summary">第 ${page}/${totalPages} 頁 · 共 ${totalItems} 篇</span>`;
}

function bindPagination(container, onPage) {
  container.querySelectorAll('button[data-page]').forEach((button) => {
    button.addEventListener('click', () => {
      const nextPage = Number(button.getAttribute('data-page'));
      if (Number.isFinite(nextPage)) onPage(nextPage);
    });
  });
}

function getPageFromUrl() {
  const page = Number(new URL(window.location.href).searchParams.get('page') || '1');
  return Number.isFinite(page) && page > 0 ? Math.floor(page) : 1;
}

function setPageInUrl(page) {
  const url = new URL(window.location.href);
  url.searchParams.set('page', String(page));
  window.history.replaceState({}, '', url);
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

loadArchive();
</script>
