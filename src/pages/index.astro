---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { PenLine, Sparkles, Languages, Pin } from 'lucide-astro';
import {
  getDB,
  getFeaturedArticle,
  listPublishedArticles,
  countPublishedArticles,
  listCategories,
  type ArticleWithMeta,
} from '../lib/db';
import { coverThumb } from '../lib/cover';

const description = 'Sammy 的 AI 工程筆記 — 架構、工具、實戰、安全。';

const PAGE_SIZE = 8;
const pageParam = Number(Astro.url.searchParams.get('page') || '1');
const page = Number.isFinite(pageParam) && pageParam > 0 ? Math.floor(pageParam) : 1;
const authorshipParam = Astro.url.searchParams.get('authorship') || '';
const authorship = ['original', 'ai', 'translation'].includes(authorshipParam) ? authorshipParam : '';

let featured: ArticleWithMeta | null = null;
let pinned: ArticleWithMeta[] = [];
let articles: ArticleWithMeta[] = [];
let categories: any[] = [];
let total = 0;

try {
  const db = getDB(Astro);
  [featured, pinned, articles, categories, total] = await Promise.all([
    getFeaturedArticle(db),
    listPublishedArticles(db, { pinnedOnly: true, limit: 5 }),
    listPublishedArticles(db, {
      authorship: authorship || undefined,
      limit: PAGE_SIZE,
      offset: (page - 1) * PAGE_SIZE,
    }),
    listCategories(db),
    countPublishedArticles(db, { authorship: authorship || undefined }),
  ]);
} catch (e) {
  console.error('Home SSR failed:', e);
}

// 今日觀點：後台勾選 is_featured 的最新一篇；沒有就退回最新文章
if (!featured && articles.length > 0) featured = articles[0];

// 右欄：置頂優先，不足補最新（排除今日觀點與已置頂）
const sideList = [
  ...pinned,
  ...articles.filter((a) => a.id !== featured?.id && !pinned.some((p) => p.id === a.id)),
].slice(0, 5);

const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));

const AUTHORSHIP_TABS = [
  { key: '', label: '全部' },
  { key: 'original', label: '觀點' },
  { key: 'ai', label: 'AI 精選' },
  { key: 'translation', label: '譯文' },
];

const DECISION_LABEL: Record<string, string> = { adopt: 'Adopt', trial: 'Trial', watch: 'Watch', avoid: 'Avoid' };

function href(opts: { page?: number; authorship?: string }) {
  const params = new URLSearchParams();
  const a = opts.authorship ?? authorship;
  const p = opts.page ?? 1;
  if (a) params.set('authorship', a);
  if (p > 1) params.set('page', String(p));
  const qs = params.toString();
  return qs ? `/?${qs}#latest` : '/';
}

function formatDate(value: string | null) {
  if (!value) return '';
  return new Date(value).toLocaleDateString('zh-TW');
}

function formatDay(value: string | null) {
  if (!value) return '--';
  return String(new Date(value).getDate()).padStart(2, '0');
}

function formatMonth(value: string | null) {
  if (!value) return '';
  return new Date(value).toLocaleDateString('zh-TW', { month: 'short' });
}

function sourceName(article: ArticleWithMeta) {
  return article.source_type || '本站筆記';
}

function whyRead(article: ArticleWithMeta) {
  const category = article.category?.slug || '';
  if (category === 'security') return '可能影響資料隔離、權限與企業導入風險。';
  if (category === 'architecture') return '可作為系統設計、平台治理或雲端架構參考。';
  if (category === 'tools') return '可能改變日常開發工具鏈與團隊效率。';
  if (category === 'tutorial') return '可直接轉成實作步驟或內部教學。';
  if (article.source_url) return '有原文可追，適合快速判斷是否值得深讀。';
  return '整理成工程筆記，適合快速補上下文。';
}
---

<BaseLayout title="reads.3mi.ai" description={description}>
  {!featured && articles.length === 0 ? (
    <div class="empty-state">
      <p>還沒有文章。</p>
      <p style="margin-top: 8px;"><a href="/admin/new">寫第一篇 →</a></p>
    </div>
  ) : (
    <>
      <section class="lead-grid" id="must-read">
        {featured && (
          <a href={`/post/${featured.slug}`} class="lead-signal lead-signal--calm">
            <span>今日觀點</span>
            <h2>{featured.title}</h2>
            <p>{featured.excerpt || ''}</p>
            <small>{formatDate(featured.published_at)} · {featured.category?.name || 'AI'} · {sourceName(featured)}</small>
          </a>
        )}
        <aside class="pinned-rail" aria-label="置頂精選">
          <h2>置頂精選</h2>
          <ul>
            {sideList.map((a) => (
              <li>
                <a href={`/post/${a.slug}`}>
                  {a.is_pinned ? <Pin size={13} /> : null}
                  <span>{a.title}</span>
                </a>
                <small>{formatDate(a.published_at)}{a.category ? ` · ${a.category.name}` : ''}</small>
              </li>
            ))}
          </ul>
        </aside>
      </section>

      <section class="channel-strip">
        {categories.map((cat) => (
          <a href={`/category/${cat.slug}`} class="channel-pill">
            <span>{cat.name}</span>
            <strong>{cat.article_count || 0}</strong>
          </a>
        ))}
      </section>

      <section class="section-block" id="latest">
        <div class="section-heading">
          <h2>Latest Signals</h2>
          <a href="/archive">文章存檔</a>
        </div>

        <nav class="authorship-tabs" aria-label="依作者身分過濾" style="margin: 14px 0 4px;">
          {AUTHORSHIP_TABS.map((tab) => (
            <a href={href({ authorship: tab.key, page: 1 })} class={authorship === tab.key ? 'active' : ''}>
              {tab.key === 'original' && <PenLine size={14} />}
              {tab.key === 'ai' && <Sparkles size={14} />}
              {tab.key === 'translation' && <Languages size={14} />}
              {tab.label}
            </a>
          ))}
        </nav>

        <div id="latest-list">
          {articles.map((article) => (
            <article class="signal-row">
              <div class="signal-date"><strong>{formatDay(article.published_at)}</strong><span>{formatMonth(article.published_at)}</span></div>
              <div class="aj-post-body">
                <div class="aj-post-meta">
                  <span class={`authorship-badge authorship-${article.authorship || 'ai'}`}>
                    {article.authorship === 'original' ? <PenLine size={14} /> : article.authorship === 'translation' ? <Languages size={14} /> : <Sparkles size={14} />}
                    {article.authorship === 'original' ? '觀點' : article.authorship === 'translation' ? '譯文' : 'AI 精選'}
                  </span>
                  {article.category && <a href={`/category/${article.category.slug}`} class="signal-category">{article.category.name}</a>}
                  <span class={`decision-badge decision-${article.decision_status || 'watch'}`}>{DECISION_LABEL[article.decision_status] || 'Watch'}</span>
                  <span>{sourceName(article)}</span>
                  <span>{article.reading_time || 1} min</span>
                </div>
                <h2><a href={`/post/${article.slug}`}>{article.title}</a></h2>
                <p>{article.excerpt || ''}</p>
                <div class="aj-post-footer">
                  <span>{whyRead(article)}</span>
                  <a href={`/post/${article.slug}`}>工程判讀 →</a>
                </div>
              </div>
              <Fragment set:html={coverThumb(article, 'card-thumb signal-thumb')} />
            </article>
          ))}
        </div>

        <nav class="pagination" aria-label="最新發布分頁">
          {totalPages <= 1 ? (
            <span class="pagination-summary">共 {total} 篇</span>
          ) : (
            <>
              {page > 1 ? <a href={href({ page: page - 1 })}>上一頁</a> : <span class="page-disabled">上一頁</span>}
              {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) =>
                p === page
                  ? <span class="active" aria-current="page">{p}</span>
                  : <a href={href({ page: p })}>{p}</a>
              )}
              {page < totalPages ? <a href={href({ page: page + 1 })}>下一頁</a> : <span class="page-disabled">下一頁</span>}
              <span class="pagination-summary">第 {page}/{totalPages} 頁 · 共 {total} 篇</span>
            </>
          )}
        </nav>
      </section>
    </>
  )}
</BaseLayout>
