---
import BaseLayout from '../layouts/BaseLayout.astro';
// 純靜態 shell — 內容由 client-side JS fetch
const description = 'Sammy 的 AI 工程筆記 — 架構、工具、實戰、安全。';
---

<BaseLayout title="news.3mi.ai" description={description}>
  <div id="home-content">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>
</BaseLayout>

<script>
async function loadHome() {
  const container = document.getElementById('home-content');
  if (!container) return;

  try {
    const [articlesRes, categoriesRes] = await Promise.all([
      fetch('/api/articles'),
      fetch('/api/categories'),
    ]);

    const { articles = [] } = await articlesRes.json();
    const { categories = [] } = await categoriesRes.json();

    if (articles.length === 0) {
      container.innerHTML = `
        <div class="empty-state">
          <p>還沒有文章。</p>
          <p style="margin-top: 8px;"><a href="/admin/new">寫第一篇 →</a></p>
        </div>`;
      return;
    }

    const featured = articles.find(article => article.is_featured) || articles[0];
    const pageSize = 8;
    const initialPage = getPageFromUrl();
    const sourceCount = articles.filter(article => article.source_url).length;
    const topics = [
      { label: 'AI Engineer World', count: 39, href: '/tag/agent' },
      { label: 'Claude Code 生存指南', count: 81, href: '/tag/tooling' },
      { label: 'AI 模型橫評', count: 271, href: '/category/ai' },
      { label: 'AI Agent 框架', count: 124, href: '/tag/agent' },
      { label: 'Codex CLI 深度', count: 306, href: '/tag/tooling' },
      { label: '多模態 AI 精讀', count: 12, href: '/archive' },
    ];

    const categoriesHtml = categories.length > 0
      ? categories.map(cat => `
          <a href="/category/${cat.slug}" class="channel-pill">
            <span>${cat.icon}</span>
            <span>${escapeHtml(cat.name)}</span>
            <strong>${cat.article_count || 0}</strong>
          </a>
        `).join('')
      : '<p class="text-muted" style="font-size: 14px;">尚無分類</p>';

    container.innerHTML = `
      <section class="aj-ad-strip">
        <a href="/about">OpenClaw 自動進料 · 工程判讀 · 來源留痕</a>
        <a href="/rss.xml">RSS 訂閱本站更新</a>
        <a href="https://3mi.ai" target="_blank" rel="noopener">Sammy Lin / 3mi.ai</a>
      </section>

      <section class="aj-topic-rail">
        ${topics.map(topic => `<a href="${topic.href}"><strong>${topic.count}</strong><span>${topic.label}</span></a>`).join('')}
      </section>

      <section class="aj-today" id="must-read">
        <a href="/post/${featured.slug}" class="aj-today-main">
          <span>今日觀點：</span>
          <h2>${escapeHtml(featured.title)}</h2>
          <p>${escapeHtml(featured.excerpt || '')}</p>
          <small>${formatDate(featured.published_at)} · ${featured.category?.name || 'AI'} · ${sourceName(featured)}</small>
        </a>
        <div class="aj-meter">
          <h3>OpenClaw · 內容流水線</h3>
          <div class="aj-meter-grid">
            <div><strong>${articles.length}</strong><span>文章</span></div>
            <div><strong>${sourceCount}</strong><span>來源</span></div>
            <div><strong>${categories.length}</strong><span>頻道</span></div>
            <div><strong>${new Date().getDate()}</strong><span>今日</span></div>
          </div>
          <p>只收會影響工具選型、架構設計、成本、安全的訊號。</p>
        </div>
      </section>

      <section class="channel-strip">${categoriesHtml}</section>

      <section class="section-block" id="latest">
        <div class="section-heading">
          <h2>最新發布</h2>
          <a href="/archive">文章存檔</a>
        </div>
        <div id="latest-list"></div>
        <nav class="pagination" id="latest-pagination" aria-label="最新發布分頁"></nav>
      </section>
    `;

    renderPagedArticles(articles, initialPage, pageSize, 'latest-list', 'latest-pagination');
  } catch (err) {
    console.error('Failed to load home data:', err);
    container.innerHTML = `
      <div class="card text-secondary" style="padding: 40px; text-align: center;">
        <p>載入失敗，請稍後再試。</p>
      </div>`;
  }
}

loadHome();

function renderPagedArticles(articles, page, pageSize, listId, paginationId) {
  const list = document.getElementById(listId);
  const pagination = document.getElementById(paginationId);
  if (!list || !pagination) return;

  const totalPages = Math.max(1, Math.ceil(articles.length / pageSize));
  const safePage = Math.min(Math.max(page, 1), totalPages);
  const start = (safePage - 1) * pageSize;
  const pageArticles = articles.slice(start, start + pageSize);

  list.innerHTML = pageArticles.map(renderAjPost).join('');
  pagination.innerHTML = renderPagination(safePage, totalPages, articles.length);
  bindPagination(pagination, (nextPage) => {
    setPageInUrl(nextPage);
    renderPagedArticles(articles, nextPage, pageSize, listId, paginationId);
  });
}

function renderAjPost(article) {
  return `
    <article class="aj-post">
      ${article.cover_image ? `<a href="/post/${article.slug}" class="aj-post-cover"><img src="${escapeAttr(article.cover_image)}" alt="${escapeAttr(article.title)}" /></a>` : `<a href="/post/${article.slug}" class="aj-post-cover aj-post-cover-fallback"><span>${article.category?.icon || 'AI'}</span></a>`}
      <div class="aj-post-body">
        <div class="aj-post-meta">
          ${article.category ? `<a href="/category/${article.category.slug}" class="tag" style="background: ${article.category.color}22; color: ${article.category.color}; border-bottom: none;">${article.category.icon || ''} ${escapeHtml(article.category.name)}</a>` : ''}
          <time>${formatDate(article.published_at)}</time>
          <span>${sourceName(article)}</span>
        </div>
        <h2><a href="/post/${article.slug}">${escapeHtml(article.title)}</a></h2>
        <p>${escapeHtml(article.excerpt || '')}</p>
        <div class="aj-post-footer">
          <span>閱讀 ${article.reading_time || 1} 分鐘</span>
          <span>${article.view_count || 0} 次瀏覽</span>
          ${article.source_url ? `<a href="${escapeAttr(article.source_url)}" target="_blank" rel="noopener">原文連結</a>` : ''}
        </div>
      </div>
    </article>`;
}

function renderPagination(page, totalPages, totalItems) {
  if (totalPages <= 1) return `<span class="pagination-summary">共 ${totalItems} 篇</span>`;
  const pages = [];
  for (let i = 1; i <= totalPages; i++) {
    pages.push(`<button type="button" data-page="${i}" ${i === page ? 'class="active" aria-current="page"' : ''}>${i}</button>`);
  }
  return `
    <button type="button" data-page="${Math.max(1, page - 1)}" ${page === 1 ? 'disabled' : ''}>上一頁</button>
    ${pages.join('')}
    <button type="button" data-page="${Math.min(totalPages, page + 1)}" ${page === totalPages ? 'disabled' : ''}>下一頁</button>
    <span class="pagination-summary">第 ${page}/${totalPages} 頁 · 共 ${totalItems} 篇</span>`;
}

function bindPagination(container, onPage) {
  container.querySelectorAll('button[data-page]').forEach((button) => {
    button.addEventListener('click', () => {
      const nextPage = Number(button.getAttribute('data-page'));
      if (Number.isFinite(nextPage)) onPage(nextPage);
    });
  });
}

function getPageFromUrl() {
  const page = Number(new URL(window.location.href).searchParams.get('page') || '1');
  return Number.isFinite(page) && page > 0 ? Math.floor(page) : 1;
}

function setPageInUrl(page) {
  const url = new URL(window.location.href);
  url.searchParams.set('page', String(page));
  window.history.replaceState({}, '', url);
}

function formatDate(value) {
  if (!value) return '';
  return new Date(value).toLocaleDateString('zh-TW');
}

function formatDay(value) {
  if (!value) return '--';
  return String(new Date(value).getDate()).padStart(2, '0');
}

function formatMonth(value) {
  if (!value) return '';
  return new Date(value).toLocaleDateString('zh-TW', { month: 'short' });
}

function sourceName(article) {
  return article.source_type ? article.source_type : '本站筆記';
}

function whyRead(article) {
  const category = article.category?.slug || '';
  if (category === 'security') return '可能影響資料隔離、權限與企業導入風險。';
  if (category === 'architecture') return '可作為系統設計、平台治理或雲端架構參考。';
  if (category === 'tools') return '可能改變日常開發工具鏈與團隊效率。';
  if (category === 'tutorial') return '可直接轉成實作步驟或內部教學。';
  if (article.source_url) return '有原文可追，適合快速判斷是否值得深讀。';
  return '整理成工程筆記，適合快速補上下文。';
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeAttr(s) {
  return escapeHtml(s).replace(/`/g, '&#96;');
}
</script>
