---
import BaseLayout from '../layouts/BaseLayout.astro';
// 純靜態 shell — 內容由 client-side JS fetch
const description = 'Sammy 的 AI 工程筆記 — 架構、工具、實戰、安全。';
---

<BaseLayout title="reads.3mi.ai" description={description}>
  <div id="home-content">
    <div class="card text-secondary" style="padding: 40px; text-align: center;">
      <p>載入中...</p>
    </div>
  </div>
</BaseLayout>

<script>
import { coverThumb } from '../lib/cover';

async function loadHome() {
  const container = document.getElementById('home-content');
  if (!container) return;

  try {
    const pageSize = 8;
    const initialPage = getPageFromUrl();
    const [articlesRes, featuredRes, categoriesRes] = await Promise.all([
      fetchArticlesPage(initialPage, pageSize),
      fetch('/api/articles?featured=1&limit=1'),
      fetch('/api/categories'),
    ]);

    const { articles = [], pagination = {}, sourceCount = 0 } = await articlesRes.json();
    const { articles: featuredArticles = [] } = await featuredRes.json();
    const { categories = [] } = await categoriesRes.json();

    if (articles.length === 0) {
      container.innerHTML = `
        <div class="empty-state">
          <p>還沒有文章。</p>
          <p style="margin-top: 8px;"><a href="/admin/new">寫第一篇 →</a></p>
        </div>`;
      return;
    }

    const featured = featuredArticles[0] || articles[0];
    const categoriesHtml = categories.length > 0
      ? categories.map(cat => `
          <a href="/category/${cat.slug}" class="channel-pill">
            <span>${escapeHtml(cat.name)}</span>
            <strong>${cat.article_count || 0}</strong>
          </a>
        `).join('')
      : '<p class="text-muted" style="font-size: 14px;">尚無分類</p>';

    container.innerHTML = `
      <section class="news-hero">
        <p class="eyebrow">Engineering Intelligence</p>
        <h1>少追新聞，<br><span>多做判斷。</span></h1>
        <p>AI、Agent、Cloud 與開發工具訊號。保留一手來源，整理工程影響，幫團隊決定現在該採用、試驗，還是觀望。</p>
        <div class="news-hero-actions">
          <a class="action-primary" href="#must-read">今日值得看</a>
          <a class="action-secondary" href="/rss.xml">RSS Feed</a>
        </div>
      </section>

      <section class="decision-strip" aria-label="內容原則">
        <div><strong>${pagination.total || articles.length}</strong><span>工程訊號</span></div>
        <div><strong>${sourceCount}</strong><span>一手來源</span></div>
        <div><strong>${categories.length}</strong><span>決策領域</span></div>
        <div><strong>4</strong><span>採用狀態</span></div>
      </section>

      <section class="lead-grid" id="must-read">
        <a href="/post/${featured.slug}" class="lead-signal">
          <span>今日值得看</span>
          <h2>${escapeHtml(featured.title)}</h2>
          <p>${escapeHtml(featured.excerpt || '')}</p>
          <small>${formatDate(featured.published_at)} · ${featured.category?.name || 'AI'} · ${sourceName(featured)}</small>
        </a>
        <div class="decision-guide">
          <p class="eyebrow">Decision Lens</p>
          <h2>每篇回答四件事</h2>
          <ol><li>發生什麼</li><li>工程影響</li><li>現在要不要採用</li><li>下一步如何驗證</li></ol>
          <a href="/about">內容方法 →</a>
        </div>
      </section>

      <section class="channel-strip">${categoriesHtml}</section>

      <section class="section-block" id="latest">
        <div class="section-heading">
          <h2>Latest Signals</h2>
          <a href="/archive">文章存檔</a>
        </div>
        <div class="authorship-tabs" id="authorship-tabs" role="tablist" aria-label="依作者身分過濾" style="margin: 14px 0 4px;"></div>
        <div id="latest-list"></div>
        <nav class="pagination" id="latest-pagination" aria-label="最新發布分頁"></nav>
      </section>
    `;

    renderAuthorshipTabs(pageSize);
    renderPagedArticles(articles, pagination, pageSize, 'latest-list', 'latest-pagination');
  } catch (err) {
    console.error('Failed to load home data:', err);
    container.innerHTML = `
      <div class="card text-secondary" style="padding: 40px; text-align: center;">
        <p>載入失敗，請稍後再試。</p>
      </div>`;
  }
}

loadHome();

async function fetchArticlesPage(page, limit) {
  const authorship = getAuthorshipFromUrl();
  const filter = authorship ? `&authorship=${authorship}` : '';
  return fetch(`/api/articles?page=${page}&limit=${limit}${filter}`);
}

// lucide inline SVG（runtime 組字串，UI 不用 emoji）
const LUCIDE_ICONS = {
  'pen-line': '<path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/>',
  sparkles: '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>',
  languages: '<path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/>',
};

function lucide(name) {
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${LUCIDE_ICONS[name] || ''}</svg>`;
}

const AUTHORSHIP = {
  original: { label: '觀點', icon: 'pen-line' },
  ai: { label: 'AI 精選', icon: 'sparkles' },
  translation: { label: '譯文', icon: 'languages' },
};

function getAuthorshipFromUrl() {
  const value = new URL(window.location.href).searchParams.get('authorship');
  return value && AUTHORSHIP[value] ? value : '';
}

function renderAuthorshipTabs(pageSize) {
  const tabs = document.getElementById('authorship-tabs');
  if (!tabs) return;
  const active = getAuthorshipFromUrl();

  tabs.innerHTML = [
    `<button type="button" data-authorship="" ${active === '' ? 'class="active"' : ''}>全部</button>`,
    ...Object.entries(AUTHORSHIP).map(([key, meta]) =>
      `<button type="button" data-authorship="${key}" ${active === key ? 'class="active"' : ''}>${lucide(meta.icon)}${meta.label}</button>`
    ),
  ].join('');

  tabs.querySelectorAll('button[data-authorship]').forEach((button) => {
    button.addEventListener('click', async () => {
      const url = new URL(window.location.href);
      const value = button.getAttribute('data-authorship');
      if (value) url.searchParams.set('authorship', value);
      else url.searchParams.delete('authorship');
      url.searchParams.delete('page');
      window.history.replaceState({}, '', url);

      tabs.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === button));
      const res = await fetchArticlesPage(1, pageSize);
      const data = await res.json();
      renderPagedArticles(data.articles || [], data.pagination || {}, pageSize, 'latest-list', 'latest-pagination');
    });
  });
}

function renderPagedArticles(articles, pageInfo, pageSize, listId, paginationId) {
  const list = document.getElementById(listId);
  const paginationEl = document.getElementById(paginationId);
  if (!list || !paginationEl) return;

  const page = pageInfo.page || 1;
  const totalPages = pageInfo.totalPages || 1;
  const total = pageInfo.total || articles.length;

  list.innerHTML = articles.map(renderAjPost).join('');
  paginationEl.innerHTML = renderPagination(page, totalPages, total);
  bindPagination(paginationEl, async (nextPage) => {
    setPageInUrl(nextPage);
    const res = await fetchArticlesPage(nextPage, pageSize);
    const data = await res.json();
    renderPagedArticles(data.articles || [], data.pagination || {}, pageSize, listId, paginationId);
  });
}

function renderAjPost(article) {
  const decision = { adopt: 'Adopt', trial: 'Trial', watch: 'Watch', avoid: 'Avoid' }[article.decision_status] || 'Watch';
  const auth = AUTHORSHIP[article.authorship] || AUTHORSHIP.ai;
  return `
    <article class="signal-row">
      <div class="signal-date"><strong>${formatDay(article.published_at)}</strong><span>${formatMonth(article.published_at)}</span></div>
      <div class="aj-post-body">
        <div class="aj-post-meta">
          <span class="authorship-badge authorship-${article.authorship || 'ai'}">${lucide(auth.icon)}${auth.label}</span>
          ${article.category ? `<a href="/category/${article.category.slug}" class="signal-category">${escapeHtml(article.category.name)}</a>` : ''}
          <span class="decision-badge decision-${article.decision_status || 'watch'}">${decision}</span>
          <span>${sourceName(article)}</span>
          <span>${article.reading_time || 1} min</span>
        </div>
        <h2><a href="/post/${article.slug}">${escapeHtml(article.title)}</a></h2>
        <p>${escapeHtml(article.excerpt || '')}</p>
        <div class="aj-post-footer">
          <span>${whyRead(article)}</span>
          <a href="/post/${article.slug}">工程判讀 →</a>
        </div>
      </div>
      ${coverThumb(article, 'card-thumb signal-thumb')}
    </article>`;
}

function renderPagination(page, totalPages, totalItems) {
  if (totalPages <= 1) return `<span class="pagination-summary">共 ${totalItems} 篇</span>`;
  const pages = [];
  for (let i = 1; i <= totalPages; i++) {
    pages.push(`<button type="button" data-page="${i}" ${i === page ? 'class="active" aria-current="page"' : ''}>${i}</button>`);
  }
  return `
    <button type="button" data-page="${Math.max(1, page - 1)}" ${page === 1 ? 'disabled' : ''}>上一頁</button>
    ${pages.join('')}
    <button type="button" data-page="${Math.min(totalPages, page + 1)}" ${page === totalPages ? 'disabled' : ''}>下一頁</button>
    <span class="pagination-summary">第 ${page}/${totalPages} 頁 · 共 ${totalItems} 篇</span>`;
}

function bindPagination(container, onPage) {
  container.querySelectorAll('button[data-page]').forEach((button) => {
    button.addEventListener('click', () => {
      const nextPage = Number(button.getAttribute('data-page'));
      if (Number.isFinite(nextPage)) onPage(nextPage);
    });
  });
}

function getPageFromUrl() {
  const page = Number(new URL(window.location.href).searchParams.get('page') || '1');
  return Number.isFinite(page) && page > 0 ? Math.floor(page) : 1;
}

function setPageInUrl(page) {
  const url = new URL(window.location.href);
  url.searchParams.set('page', String(page));
  window.history.replaceState({}, '', url);
}

function formatDate(value) {
  if (!value) return '';
  return new Date(value).toLocaleDateString('zh-TW');
}

function formatDay(value) {
  if (!value) return '--';
  return String(new Date(value).getDate()).padStart(2, '0');
}

function formatMonth(value) {
  if (!value) return '';
  return new Date(value).toLocaleDateString('zh-TW', { month: 'short' });
}

function sourceName(article) {
  return article.source_type ? article.source_type : '本站筆記';
}

function whyRead(article) {
  const category = article.category?.slug || '';
  if (category === 'security') return '可能影響資料隔離、權限與企業導入風險。';
  if (category === 'architecture') return '可作為系統設計、平台治理或雲端架構參考。';
  if (category === 'tools') return '可能改變日常開發工具鏈與團隊效率。';
  if (category === 'tutorial') return '可直接轉成實作步驟或內部教學。';
  if (article.source_url) return '有原文可追，適合快速判斷是否值得深讀。';
  return '整理成工程筆記，適合快速補上下文。';
}

function escapeHtml(s) {
  if (typeof s !== 'string') return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeAttr(s) {
  return escapeHtml(s).replace(/`/g, '&#96;');
}
</script>
