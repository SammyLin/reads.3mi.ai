---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — 找不到頁面" description="頁面不存在" showSidebars={false}>
  <div style="text-align: center; padding: 80px 20px;">
    <h1 style="font-size: 96px; font-weight: 700; color: var(--accent); margin-bottom: 16px;">404</h1>
    <p style="font-size: 20px; color: var(--text-secondary); margin-bottom: 32px;">這頁不存在</p>
    <a href="/" class="btn btn-primary">回到首頁</a>
  </div>
</BaseLayout>