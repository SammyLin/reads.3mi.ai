---
const pathname = Astro.url.pathname;
const nav = [
  { href: '/', label: '首頁' },
  { href: '/archive', label: '文章' },
  { href: '/tags', label: '標籤' },
  { href: '/about', label: '關於' },
];
---

<header class="site-header">
  <div class="container">
    <a href="/" class="site-logo">
      <span>news.3mi.ai</span>
      <span class="tag">AI 工程筆記</span>
    </a>
    <nav class="site-nav">
      {nav.map((item) => (
        <a href={item.href} class={pathname === item.href ? 'active' : ''}>{item.label}</a>
      ))}
      <a href="/admin" class={pathname.startsWith('/admin') ? 'active' : ''}>後台</a>
    </nav>
  </div>
</header>