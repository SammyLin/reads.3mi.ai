---
const pathname = Astro.url.pathname;
const nav = [
  { href: '/', label: '首頁' },
  { href: '/series', label: '主題合集' },
  { href: '/trending', label: '熱門' },
  { href: '/category/architecture', label: '架構' },
  { href: '/category/tutorial', label: '實戰' },
  { href: '/category/tools', label: '工具' },
  { href: '/archive', label: '存檔' },
];
---

<header class="site-header">
  <div class="container">
    <a href="/" class="site-logo">
      <img class="brand-mark" src="/favicon.svg" width="34" height="34" alt="" />
      <span class="logo-title">3mi<span>.ai</span></span>
      <span class="logo-divider"></span>
      <span class="logo-section">News</span>
    </a>
    <nav class="site-nav">
      {nav.map((item) => (
        <a href={item.href} class={pathname === item.href || pathname.startsWith(`${item.href}/`) ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>
    <nav class="product-nav" aria-label="3mi 產品">
      <a href="https://3mi.ai">3mi</a>
      <a href="/" class="active" aria-current="page">News</a>
      <a href="https://trending.3mi.ai">Trending</a>
      <a href="https://chunkup.3mi.ai">ChunkUp</a>
    </nav>
  </div>
</header>
