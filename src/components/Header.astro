---
const pathname = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Signals' },
  { href: '/category/architecture', label: 'Architecture' },
  { href: '/category/tools', label: 'Tools' },
  { href: '/archive', label: 'Archive' },
  { href: '/about', label: '關於' },
];
---

<header class="site-header">
  <div class="container">
    <a href="/" class="site-logo">
      <span class="logo-title">3mi<span>.ai</span></span>
      <span class="logo-divider"></span>
      <span class="logo-section">News</span>
    </a>
    <nav class="site-nav">
      {nav.map((item) => (
        <a href={item.href} class={pathname === item.href || pathname.startsWith(`${item.href}/`) ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
