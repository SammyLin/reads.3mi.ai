{
  "name": "news-3mi",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "wrangler:dev": "wrangler pages dev ./dist --d1=DB --r2=BUCKET --compatibility-date=2026-01-01",
    "db:migrate:local": "wrangler d1 execute news-3mi-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute news-3mi-db --remote --file=migrations/0001_init.sql",
    "db:seed:local": "wrangler d1 execute news-3mi-db --local --file=migrations/seed.sql"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "^11.2.0",
    "@astrojs/react": "^3.6.3",
