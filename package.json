    "@astrojs/sitemap": "^3.2.1",
    "astro": "^4.16.18",
    "dompurify": "^3.2.3",
    "highlight.js": "^11.10.0",
    "jsdom": "^25.0.1",
    "lucide-astro": "^0.556.0",
    "marked": "^14.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
